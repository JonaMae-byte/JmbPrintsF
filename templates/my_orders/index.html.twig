{% extends 'base.html.twig' %}

{% block title %}My Orders | JMB Prints{% endblock %}

{% block body %}
<style>
/* ========= CUSTOMER NAVBAR - CONSISTENT WITH CART ========= */
.customer-navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: linear-gradient(180deg, #005b96 0%, #007bff 100%);
    padding: 16px 40px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 2000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 24px;
    font-weight: 700;
    color: white;
    text-decoration: none;
    transition: all 0.3s ease;
}

.nav-logo:hover {
    transform: scale(1.05);
    color: white;
}

.nav-logo i {
    color: white;
}

.nav-actions {
    display: flex;
    align-items: center;
    gap: 28px;
}

.nav-cart-link {
    position: relative;
    font-size: 24px;
    color: white;
    text-decoration: none;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
}

.nav-cart-link:hover {
    color: rgba(255, 255, 255, 0.8);
    transform: scale(1.1);
}

.nav-cart-badge {
    position: absolute;
    top: -8px;
    right: -12px;
    background: linear-gradient(135deg, #dc3545, #c82333);
    color: white;
    border-radius: 50%;
    min-width: 22px;
    height: 22px;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(220, 53, 69, 0.4);
}

.profile-menu {
    position: relative;
}

.profile-trigger {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.profile-trigger:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.3);
}

.profile-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 16px;
}

.profile-name {
    font-weight: 600;
    color: white;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
}

.profile-name i {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.7);
}

.profile-dropdown {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    background: white;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    border-radius: 12px;
    overflow: hidden;
    min-width: 200px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    animation: dropdownFade 0.3s ease-out;
}

@keyframes dropdownFade {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.profile-menu:hover .profile-dropdown {
    display: block;
}

.profile-dropdown a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    text-decoration: none;
    color: #4a5568;
    font-size: 15px;
    font-weight: 500;
    transition: all 0.2s ease;
}

.profile-dropdown a:hover {
    background: #f8f9fa;
    color: #007bff;
    padding-left: 24px;
}

.profile-dropdown a i {
    font-size: 16px;
    width: 20px;
    text-align: center;
}

.profile-dropdown a.active {
    background: #e3f2fd;
    color: #007bff;
}

.divider {
    height: 1px;
    background: #e2e8f0;
    margin: 6px 0;
}

.logout {
    color: #dc3545 !important;
}

.logout:hover {
    background: #fee !important;
    color: #dc3545 !important;
}

/* ========= ORDERS PAGE STYLES ========= */
.orders-container {
    padding: 32px;
    padding-top: 110px;
    max-width: 1200px;
    margin: 0 auto;
}

/* ========= PAGE HEADER ========= */
.orders-header {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 24px 32px;
    border-radius: 16px;
    margin-bottom: 32px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.5);
    animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.orders-header h1 {
    font-size: 32px;
    font-weight: 700;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0;
}

/* ========= ALERTS ========= */
.alert {
    padding: 16px 20px;
    border-radius: 12px;
    margin-bottom: 24px;
    font-size: 15px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 12px;
    animation: slideIn 0.4s ease-out;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.alert-success {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    color: #155724;
    border: 1px solid #c3e6cb;
}

.alert-danger {
    background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
    color: #721c24;
    border: 1px solid #f5c6cb;
}

.alert-info {
    background: linear-gradient(135deg, #d1ecf1 0%, #bee5eb 100%);
    color: #0c5460;
    border: 1px solid #bee5eb;
}

/* ========= EMPTY STATE ========= */
.empty-orders {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    padding: 80px 40px;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.5);
}

.empty-orders i {
    font-size: 80px;
    color: #cbd5e0;
    margin-bottom: 24px;
}

.empty-orders h3 {
    font-size: 24px;
    color: #4a5568;
    margin-bottom: 12px;
}

.empty-orders p {
    color: #718096;
    font-size: 16px;
    margin-bottom: 32px;
}

.btn-start-shop {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    color: white;
    padding: 14px 32px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(0, 91, 150, 0.3);
}

.btn-start-shop:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 91, 150, 0.4);
    color: white;
}

/* ========= ORDERS TABLE ========= */
.orders-content {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.5);
}

.orders-table {
    width: 100%;
    border-collapse: collapse;
}

.orders-table thead {
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
}

.orders-table th {
    color: white;
    padding: 16px 20px;
    text-transform: uppercase;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-align: left;
}

.orders-table tbody tr {
    border-bottom: 1px solid #e2e8f0;
    transition: all 0.2s ease;
}

.orders-table tbody tr:hover {
    background-color: #f8f9fa;
}

.orders-table td {
    padding: 20px;
    font-size: 15px;
    color: #4a5568;
    vertical-align: top;
}

.order-id {
    font-weight: 700;
    color: #005b96;
    font-size: 16px;
}

.order-items {
    list-style: none;
    padding: 0;
    margin: 0;
}

.order-items li {
    padding: 4px 0;
    color: #4a5568;
}

.order-items li:before {
    content: "•";
    color: #007bff;
    font-weight: bold;
    display: inline-block;
    width: 1em;
    margin-left: -1em;
}

.order-total {
    font-weight: 700;
    font-size: 16px;
    color: #28a745;
}

/* ========= STATUS BADGES ========= */
.status-badge {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.status-pending {
    background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
    color: #856404;
    border: 1px solid #ffeaa7;
}

.status-processing {
    background: linear-gradient(135deg, #cfe2ff 0%, #9ec5fe 100%);
    color: #084298;
    border: 1px solid #9ec5fe;
}

.status-completed {
    background: linear-gradient(135deg, #d1e7dd 0%, #a3cfbb 100%);
    color: #0f5132;
    border: 1px solid #a3cfbb;
}

.status-cancelled {
    background: linear-gradient(135deg, #f8d7da 0%, #f1aeb5 100%);
    color: #842029;
    border: 1px solid #f1aeb5;
}

/* ========= ACTION BUTTONS ========= */
.btn-view {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(135deg, #17a2b8, #138496);
    color: white;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(23, 162, 184, 0.3);
}

.btn-view:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(23, 162, 184, 0.4);
    color: white;
}

.btn-cancel {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(135deg, #dc3545, #c82333);
    color: white;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(220, 53, 69, 0.3);
    margin-left: 8px;
}

.btn-cancel:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(220, 53, 69, 0.4);
    color: white;
}

.no-actions {
    color: #a0aec0;
    font-style: italic;
    font-size: 14px;
}

/* ========= RESPONSIVE ========= */
@media (max-width: 992px) {
    .orders-table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
    }

    .profile-name span {
        display: none;
    }
}

@media (max-width: 768px) {
    .customer-navbar {
        padding: 12px 20px;
    }

    .nav-logo {
        font-size: 18px;
    }

    .nav-actions {
        gap: 20px;
    }

    .orders-container {
        padding: 20px;
        padding-top: 90px;
    }

    .orders-header {
        padding: 20px;
    }

    .orders-header h1 {
        font-size: 24px;
    }

    .orders-content {
        padding: 20px;
    }

    .orders-table th,
    .orders-table td {
        padding: 12px;
        font-size: 14px;
    }

    .btn-view,
    .btn-cancel {
        padding: 6px 12px;
        font-size: 13px;
    }
}
</style>

<!-- Customer Navigation Bar -->
<nav class="customer-navbar">
    <a href="{{ path('app_ordering') }}" class="nav-logo">
        <i class="fas fa-store"></i>
        <span>JMB Prints</span>
    </a>

    <div class="nav-actions">
        <!-- Cart Icon -->
        <a href="{{ path('cart_index') }}" class="nav-cart-link">
            <i class="fas fa-shopping-cart"></i>
            <span id="cartCount" class="nav-cart-badge">{{ cart_count|default(0) }}</span>
        </a>

        <!-- Profile Dropdown -->
        <div class="profile-menu">
            <div class="profile-trigger">
                <div class="profile-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="profile-name">
                    <span>{{ app.user.username|default('User') }}</span>
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>

            <div class="profile-dropdown">
                
                <a href="{{ path('my_orders') }}" class="active">
                    <i class="fas fa-shopping-bag"></i>
                    My Orders
                </a>
                
                <div class="divider"></div>
                <a href="{{ path('app_logout') }}" class="logout">
                    <i class="fas fa-sign-out-alt"></i>
                    Logout
                </a>
            </div>
        </div>
    </div>
</nav>

<div class="orders-container">
    <div class="orders-header">
        <h1>📦 My Orders</h1>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            {{ message }}
        </div>
    {% endfor %}

    {% if orders is empty %}
        <div class="empty-orders">
            <i class="fas fa-box-open"></i>
            <h3>No Orders Yet</h3>
            <p>You haven't placed any orders. Start shopping to see your orders here!</p>
            <a href="{{ path('app_ordering') }}" class="btn-start-shop">
                <i class="fas fa-shopping-bag"></i>
                Start Shopping
            </a>
        </div>
    {% else %}
        <div class="orders-content">
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Items</th>
                        <th>Total Price</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    {% for order in orders %}
                        {% set total = 0 %}
                        {% for item in order.orderItems %}
                            {% set total = total + item.subtotal %}
                        {% endfor %}

                        <tr>
                            <td class="order-id">#{{ order.id }}</td>

                            <td>
                                <ul class="order-items">
                                    {% for item in order.orderItems %}
                                        <li>{{ item.product.name }} (x{{ item.quantity }})</li>
                                    {% endfor %}
                                </ul>
                            </td>

                            <td class="order-total">₱{{ total|number_format(2) }}</td>

                            <td>
                                {% if order.status == 'Pending' %}
                                    <span class="status-badge status-pending">Pending</span>
                                {% elseif order.status == 'Processing' %}
                                    <span class="status-badge status-processing">Processing</span>
                                {% elseif order.status == 'Completed' %}
                                    <span class="status-badge status-completed">Completed</span>
                                {% elseif order.status == 'Cancelled' %}
                                    <span class="status-badge status-cancelled">Cancelled</span>
                                {% endif %}
                            </td>

                            <td>
                                <a href="{{ path('my_orders_view', {id: order.id}) }}"
                                   class="btn-view">
                                    <i class="fas fa-eye"></i>
                                    View
                                </a>

                                {% if order.status == 'Pending' %}
                                    <a href="{{ path('my_orders_cancel', {id: order.id}) }}"
                                       class="btn-cancel"
                                       onclick="return confirm('Cancel this order?');">
                                        <i class="fas fa-times-circle"></i>
                                        Cancel
                                    </a>
                                {% else %}
                                    <span class="no-actions">No actions</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

<script>
// Update cart count on page load
function updateCartBadge() {
    fetch("/cart/count")
        .then(r => r.json())
        .then(data => {
            document.getElementById("cartCount").textContent = data.count;
        })
        .catch(() => {});
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    updateCartBadge();
});
</script>

{% endblock %}