{{ form_start(form, {'attr': {'class': 'space-y-6 bg-white p-8 rounded-2xl shadow-md max-w-lg mx-auto'}}) }}

    <div class="text-center mb-4">
        <h2 class="text-2xl font-semibold text-gray-700">
            {{ button_label == 'Update' ? 'Edit Category' : 'Create New Category' }}
        </h2>
        <p class="text-sm text-gray-500">Fill in the details below to continue.</p>
    </div>

    <div class="space-y-4">
        {% for field in form %}
            <div>
                {{ form_label(field, null, {'label_attr': {'class': 'block mb-1 font-medium text-gray-700'}}) }}
                {{ form_widget(field, {'attr': {'class': 'w-full border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 focus:outline-none'}}) }}
                {{ form_errors(field) }}
            </div>
        {% endfor %}
    </div>

    <div class="flex justify-between items-center mt-6">
        <a href="{{ path('app_category_index') }}" 
           class="px-4 py-2 text-gray-600 hover:text-blue-600 transition">
            ← Back to List
        </a>

        <button class="px-5 py-2 bg-blue-600 text-white rounded-lg shadow hover:bg-blue-700 transition">
            {{ button_label|default('Save') }}
        </button>
    </div>

{{ form_end(form) }}
