{% extends 'base.html.twig' %}

{% block title %}Settings ⚙️ | JMB Prints{% endblock %}

{% block body %}
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

body { 
  font-family: "Poppins", sans-serif; 
  background: linear-gradient(135deg, #e3f2fd 0%, #f5f6fa 100%);
  padding: 30px 20px;
  min-height: 100vh;
}

.settings-container { 
  display: flex; 
  background: white; 
  border-radius: 20px; 
  box-shadow: 0 8px 30px rgba(0, 123, 255, 0.12); 
  margin: 0 auto; 
  max-width: 1400px; 
  overflow: hidden;
  border: 1px solid rgba(0, 123, 255, 0.1);
}

.settings-sidebar { 
  width: 280px; 
  background: linear-gradient(180deg, #f8f9fb 0%, #ffffff 100%);
  border-right: 1px solid #e8f1fc; 
  padding: 30px 20px;
}

.settings-sidebar h3 { 
  font-size: 22px; 
  margin-bottom: 25px; 
  color: #007bff; 
  font-weight: 700;
  padding-bottom: 15px;
  border-bottom: 3px solid #007bff;
}

.settings-sidebar ul { 
  list-style: none; 
  padding: 0; 
}

.settings-sidebar li { 
  margin-bottom: 8px; 
}

.settings-sidebar a { 
  color: #555; 
  text-decoration: none; 
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px; 
  border-radius: 12px; 
  transition: all 0.3s ease;
  font-size: 15px;
  font-weight: 500;
}

.settings-sidebar a::before {
  content: '⚙️';
  font-size: 18px;
}

.settings-sidebar a.active, 
.settings-sidebar a:hover { 
  background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
  color: white;
  transform: translateX(5px);
  box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
}

.settings-content { 
  flex: 1; 
  padding: 40px 50px;
  overflow-y: auto;
  max-height: 85vh;
}

.alert {
  padding: 14px 20px;
  border-radius: 12px;
  margin-bottom: 25px;
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10px;
  animation: slideDown 0.4s ease;
}

.alert-success {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #065f46;
  border-left: 4px solid #10b981;
}

.alert-success::before {
  content: '✅';
  font-size: 18px;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

.profile-section { 
  display: flex; 
  align-items: center; 
  gap: 25px; 
  margin-bottom: 35px;
  padding: 25px;
  background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%);
  border-radius: 16px;
  border: 1px solid #e8f1fc;
}

.profile-image-wrapper {
  position: relative;
}

.profile-section img { 
  width: 110px; 
  height: 110px; 
  border-radius: 50%; 
  object-fit: cover;
  border: 4px solid #007bff;
  box-shadow: 0 4px 15px rgba(0, 123, 255, 0.2);
}

.profile-info { 
  flex: 1;
}

.profile-info h4 { 
  margin: 0 0 8px 0; 
  font-size: 24px; 
  font-weight: 700;
  color: #007bff;
}

.profile-info p { 
  margin: 0; 
  color: #6b7280; 
  font-size: 14px;
  line-height: 1.5;
}

.btn-change-logo { 
  background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
  border: none; 
  color: white; 
  padding: 12px 24px; 
  border-radius: 12px; 
  cursor: pointer; 
  font-size: 14px;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
  display: flex;
  align-items: center;
  gap: 8px;
}

.btn-change-logo::before {
  content: '📸';
  font-size: 16px;
}

.btn-change-logo:hover { 
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 123, 255, 0.4);
}

.section-header {
  margin: 35px 0 20px 0;
  padding-bottom: 12px;
  border-bottom: 2px solid #e8f1fc;
}

.section-header h3 {
  color: #007bff;
  font-size: 18px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 10px;
}

.settings-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.form-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-group.full-width {
  grid-column: 1 / -1;
}

.form-group label {
  font-weight: 600;
  color: #333;
  font-size: 14px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.form-group label::before {
  content: '●';
  color: #007bff;
  font-size: 8px;
}

.form-group input, 
.form-group textarea,
.form-group select {
  padding: 12px 16px;
  border: 2px solid #e8f1fc;
  border-radius: 10px;
  font-size: 14px;
  font-family: "Poppins", sans-serif;
  transition: all 0.3s ease;
  background: white;
}

.form-group input:focus, 
.form-group textarea:focus,
.form-group select:focus {
  outline: none;
  border-color: #007bff;
  box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
}

.form-group textarea { 
  resize: vertical; 
  min-height: 80px;
  max-height: 200px;
}

.form-group input::placeholder,
.form-group textarea::placeholder {
  color: #9ca3af;
}

.action-buttons {
  display: flex;
  gap: 15px;
  margin-top: 30px;
  padding-top: 25px;
  border-top: 2px solid #e8f1fc;
}

.btn-save { 
  background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
  border: none; 
  color: white; 
  padding: 14px 32px; 
  border-radius: 12px; 
  cursor: pointer;
  font-size: 15px;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
  display: flex;
  align-items: center;
  gap: 8px;
}

.btn-save::before {
  content: '💾';
  font-size: 16px;
}

.btn-save:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 123, 255, 0.4);
}

.btn-reset {
  background: white;
  border: 2px solid #e8f1fc;
  color: #6b7280;
  padding: 14px 32px;
  border-radius: 12px;
  cursor: pointer;
  font-size: 15px;
  font-weight: 600;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 8px;
}

.btn-reset::before {
  content: '🔄';
  font-size: 16px;
}

.btn-reset:hover {
  border-color: #007bff;
  color: #007bff;
  background: #f0f7ff;
}

@media (max-width: 1200px) {
  .settings-container {
    flex-direction: column;
  }
  
  .settings-sidebar {
    width: 100%;
    border-right: none;
    border-bottom: 1px solid #e8f1fc;
  }
  
  .settings-sidebar ul {
    display: flex;
    gap: 10px;
    overflow-x: auto;
  }
  
  .settings-sidebar li {
    margin-bottom: 0;
  }
}

@media (max-width: 768px) {
  .settings-content {
    padding: 25px 20px;
  }
  
  .profile-section {
    flex-direction: column;
    text-align: center;
  }
  
  .form-row {
    grid-template-columns: 1fr;
  }
  
  .action-buttons {
    flex-direction: column;
  }
  
  .btn-save,
  .btn-reset {
    width: 100%;
    justify-content: center;
  }
}
</style>

<div class="settings-container">
  <div class="settings-sidebar">
    <h3>Settings</h3>
    <ul>
      <li><a href="#" class="active">General</a></li>
    </ul>
  </div>

  <div class="settings-content">
    <div class="profile-section">
      <div class="profile-image-wrapper">
        <img src="{{ asset('SADlogo.png') }}" alt="Profile Picture">
      </div>
      <div class="profile-info">
        <h4>{{ settings.name is defined ? settings.name : 'JMB Prints' }}</h4>
        <p>Manage your default system settings and preferences. Customize your workspace to match your workflow.</p>
      </div>
      <button class="btn-change-logo">Change Logo</button>
    </div>

    {% if success is defined %}
      <div class="alert alert-success">
        {{ success }}
      </div>
    {% endif %}

    <form action="{{ path('app_settings_update') }}" method="POST">

      <div class="section-header">
        <h3>🏢 Business Information</h3>
      </div>

      <div class="settings-form">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Business Name</label>
            <input type="text" name="name" id="name" 
                   value="{{ settings.name is defined ? settings.name : '' }}"
                   placeholder="Enter business name">
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" name="email" id="email" 
                   value="{{ settings.email is defined ? settings.email : '' }}"
                   placeholder="business@example.com">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="text" name="phone" id="phone" 
                   value="{{ settings.phone is defined ? settings.phone : '' }}"
                   placeholder="+63 912 345 6789">
          </div>

          <div class="form-group">
            <label for="website">Website</label>
            <input type="text" name="website" id="website" 
                   value="{{ settings.website is defined ? settings.website : '' }}"
                   placeholder="https://www.example.com">
          </div>
        </div>

        <div class="form-group full-width">
          <label for="address">Business Address</label>
          <textarea name="address" id="address" 
                    placeholder="Enter complete business address">{{ settings.address is defined ? settings.address : '' }}</textarea>
        </div>
      </div>

      <div class="action-buttons">
        <button type="submit" class="btn-save">Save Changes</button>
        <button type="reset" class="btn-reset">Reset to Default</button>
      </div>
    </form>
  </div>
</div>

<script>
document.querySelector('form').addEventListener('submit', function(e) {
  const requiredFields = ['name', 'email', 'phone'];
  let isValid = true;
  
  requiredFields.forEach(field => {
    const input = document.getElementById(field);
    if (!input.value.trim()) {
      input.style.borderColor = '#ef4444';
      isValid = false;
    } else {
      input.style.borderColor = '#e8f1fc';
    }
  });
  
  if (!isValid) {
    e.preventDefault();
    alert('Please fill in all required fields (Name, Email, Phone)');
  }
});

document.querySelector('.btn-reset').addEventListener('click', function(e) {
  if (!confirm('Are you sure you want to reset all settings to default?')) {
    e.preventDefault();
  }
});

let saveTimeout;
document.querySelectorAll('input, textarea, select').forEach(field => {
  field.addEventListener('input', function() {
    clearTimeout(saveTimeout);
    saveTimeout = setTimeout(() => {
      document.querySelector('.btn-save').style.animation = 'pulse 0.5s';
      setTimeout(() => {
        document.querySelector('.btn-save').style.animation = '';
      }, 500);
    }, 1000);
  });
});
</script>
{% endblock %}