{% extends 'base.html.twig' %}

{% block title %}Login | JMB Prints{% endblock %}

{% block body %}
<style>
/* ========================================
   AUTHENTICATION PAGES STYLES
======================================== */

.auth-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background-color: #f7f9fc;
    position: relative;
}

.auth-layout {
    width: 100%;
    max-width: 1080px;
    display: grid;
    grid-template-columns: minmax(320px, 440px) minmax(360px, 1fr);
    gap: 24px;
    align-items: stretch;
    position: relative;
    z-index: 1;
}

.auth-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
        linear-gradient(135deg, rgba(0, 91, 150, 0.03) 0%, rgba(0, 123, 255, 0.03) 100%);
    pointer-events: none;
}

.auth-card {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 48px 40px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.5);
    width: 100%;
    max-width: 440px;
    position: relative;
    animation: fadeInUp 0.6s ease-out;
}

.auth-visual {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    min-height: 620px;
    background: #d6ebff;
}

.auth-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ========= AUTH HEADER ========= */
.auth-header {
    text-align: center;
    margin-bottom: 32px;
}

.auth-logo {
    display: inline-block;
    margin-bottom: 24px;
}

.auth-logo img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.95);
    padding: 12px;
    border-radius: 16px;
    box-shadow: 0 4px 16px rgba(0, 91, 150, 0.15);
}

.auth-header h1 {
    font-size: 28px;
    font-weight: 700;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 8px 0;
}

.auth-header p {
    color: #718096;
    font-size: 15px;
    margin: 0;
}

/* ========= ALERTS ========= */
.alert {
    padding: 14px 18px;
    border-radius: 12px;
    margin-bottom: 24px;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.alert-error {
    background: #fee;
    color: #c53030;
    border: 1px solid #feb2b2;
}

.alert-success {
    background: #f0fdf4;
    color: #166534;
    border: 1px solid #86efac;
}

/* ========= FORM STYLES ========= */
.auth-form {
    margin-bottom: 24px;
}

.form-group {
    margin-bottom: 20px;
}

.form-label {
    display: block;
    margin-bottom: 8px;
    color: #2d3748;
    font-weight: 600;
    font-size: 14px;
}

.form-input {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 15px;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: all 0.3s ease;
    background: white;
    box-sizing: border-box;
}

.form-input:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
}

.form-input::placeholder {
    color: #a0aec0;
}

/* ========= CHECKBOX STYLES ========= */
.form-group-checkbox {
    margin-bottom: 24px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
}

.form-checkbox {
    width: 18px;
    height: 18px;
    cursor: pointer;
    flex-shrink: 0;
    margin-top: 2px;
}

.checkbox-label {
    color: #4a5568;
    font-size: 14px;
    line-height: 1.5;
    cursor: pointer;
    user-select: none;
}

.checkbox-label a {
    color: #007bff;
    text-decoration: none;
    font-weight: 600;
}

.checkbox-label a:hover {
    text-decoration: underline;
}

/* ========= SUBMIT BUTTON ========= */
.btn-submit {
    width: 100%;
    padding: 14px 24px;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(0, 91, 150, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 91, 150, 0.4);
}

.btn-submit:active {
    transform: translateY(0);
}

.auth-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0;
    color: #a0aec0;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

.auth-divider::before,
.auth-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e2e8f0;
}

.btn-google {
    width: 100%;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: #fff;
    color: #3c4043;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
}

.btn-google:hover {
    background: #f8fafc;
    border-color: #cbd5e0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    color: #1a202c;
}

.btn-google i {
    font-size: 18px;
    color: #4285f4;
}

/* ========= AUTH FOOTER ========= */
.auth-footer {
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid #e2e8f0;
}

.auth-footer p {
    color: #718096;
    font-size: 14px;
    margin: 0;
}

.auth-footer a {
    color: #007bff;
    text-decoration: none;
    font-weight: 600;
}

.auth-footer a:hover {
    text-decoration: underline;
}

/* ========= RESPONSIVE ========= */
@media (max-width: 980px) {
    .auth-layout {
        grid-template-columns: 1fr;
        max-width: 440px;
    }

    .auth-visual {
        display: none;
    }
}

@media (max-width: 480px) {
    .auth-card {
        padding: 32px 24px;
    }

    .auth-header h1 {
        font-size: 24px;
    }

    .auth-logo img {
        width: 64px;
        height: 64px;
    }
}
</style>

<div class="auth-container">
    <div class="auth-layout">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <img src="{{ asset('SADlogo.png') }}" alt="JMB Prints Logo">
                </div>
                <h1>Welcome Back</h1>
                <p>Sign in to your account</p>
            </div>

            {% for message in app.flashes('error') %}
                <div class="alert alert-error" role="alert">
                    <i class="fas fa-exclamation-circle"></i>
                    {{ message }}
                </div>
            {% endfor %}

            {% if error %}
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    You are logged in as <strong>{{ app.user.userIdentifier }}</strong>
                    <a href="{{ path('app_logout') }}" style="margin-left: 8px;">Logout</a>
                </div>
            {% endif %}

            <form method="post" class="auth-form">
                <div class="form-group">
                    <label for="inputUsername" class="form-label">Username</label>
                    <input
                        type="text"
                        value="{{ last_username }}"
                        name="username"
                        id="inputUsername"
                        class="form-input"
                        autocomplete="username"
                        placeholder="Enter your username"
                        required
                        autofocus>
                </div>

                <div class="form-group">
                    <label for="inputPassword" class="form-label">Password</label>
                    <input
                        type="password"
                        name="password"
                        id="inputPassword"
                        class="form-input"
                        autocomplete="current-password"
                        placeholder="Enter your password"
                        required>
                </div>

                <div class="form-group-checkbox">
                    <input type="checkbox" name="_remember_me" id="rememberMe" class="form-checkbox">
                    <label for="rememberMe" class="checkbox-label">Remember me</label>
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button class="btn-submit" type="submit">
                    <i class="fas fa-sign-in-alt"></i>
                    Sign In
                </button>
            </form>

            <div class="auth-divider"><span>or</span></div>

            <a href="{{ path('connect_google') }}" class="btn-google">
                <i class="fab fa-google"></i>
                Continue with Google
            </a>
            <p style="margin-top: 12px; font-size: 13px; color: #718096; text-align: center; line-height: 1.5;">
                For <strong>staff</strong> only. Your Google email must match the address on your staff account.
            </p>

            <div class="auth-footer">
                <p>Don't have an account? <a href="{{ path('app_register') }}">Register here</a></p>
            </div>
        </div>

        <div class="auth-visual" aria-hidden="true">
            <img src="{{ asset('auth-images/auth-side.png') }}" alt="">
        </div>
    </div>
</div>
{% endblock %}