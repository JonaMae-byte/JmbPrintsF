{% extends 'base.html.twig' %}

{% block title %}User Management{% endblock %}

{% block body %}
<style>
/* ========= PAGE SHELL ========= */
.page-shell {
    padding: 40px;
    margin-left: 0 !important;
    transition: none !important;
    min-height: 100vh;
}

.page-container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
}

/* ========= PAGE HEADER ========= */
.page-header {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 32px 40px;
    border-radius: 20px;
    margin-bottom: 28px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.5);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.page-header h2 {
    font-size: 38px;
    font-weight: 700;
    background: linear-gradient(135deg, #007bff 0%, #00c6ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 16px;
}

/* ========= STATS CARDS ========= */
.stats-container {
    display: flex;
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    padding: 20px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 20px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.5);
    transition: all 0.3s ease;
    flex: 1;
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
}

.stat-card h3 {
    font-size: 16px;
    font-weight: 600;
    color: #6c757d;
    margin: 0 0 12px 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stat-card p {
    font-size: 42px;
    font-weight: 700;
    background: linear-gradient(135deg, #007bff 0%, #00c6ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0;
}

/* ========= TABLE CONTAINER ========= */
.table-container {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.5);
    overflow: hidden;
}

/* ========= TABLE STYLES ========= */
.table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 0;
}

.table thead tr {
    background: linear-gradient(135deg, #007bff 0%, #00c6ff 100%);
}

.table thead th {
    padding: 18px 24px;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: white;
    border: none;
    text-align: left;
}

.table thead th:first-child {
    border-top-left-radius: 14px;
}

.table thead th:last-child {
    border-top-right-radius: 14px;
}

.table tbody tr {
    transition: all 0.2s ease;
    background: white;
}

.table tbody tr:hover {
    background: rgba(255, 255, 255, 0.75);
    transform: scale(1.01);
    box-shadow: 0 6px 14px rgba(75, 97, 194, 0.16);
}

.table tbody tr:hover td {
    color:rgb(126, 157, 230) !important;
}

.table tbody td {
    padding: 20px 24px;
    border-bottom: 1px solid #e9ecef;
    font-size: 15px;
    color: #1f2937 !important;
}

.table tbody td:nth-child(2) {
    color: #0f172a !important;
    font-weight: 600;
}

.table tbody tr:last-child td {
    border-bottom: none;
}

.table tbody tr:last-child td:first-child {
    border-bottom-left-radius: 14px;
}

.table tbody tr:last-child td:last-child {
    border-bottom-right-radius: 14px;
}

/* ========= BUTTONS ========= */
.btn {
    padding: 12px 28px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: none;
    cursor: pointer;
}

.btn-primary {
    background: linear-gradient(135deg, #007bff, #00c6ff);
    color: white;
    box-shadow: 0 6px 16px rgba(0, 123, 255, 0.35);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 123, 255, 0.45);
}

.btn-sm {
    padding: 8px 18px;
    font-size: 14px;
    border-radius: 10px;
}

.btn-warning {
    background: linear-gradient(135deg, #ffc107, #ffb300);
    color: #212529;
    box-shadow: 0 4px 12px rgba(255, 193, 7, 0.35);
}

.btn-warning:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(255, 193, 7, 0.45);
}

.btn-danger {
    background: linear-gradient(135deg, #dc3545, #c82333);
    color: white;
    box-shadow: 0 4px 12px rgba(220, 53, 69, 0.35);
}

.btn-danger:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(220, 53, 69, 0.45);
}

/* ========= RESPONSIVE ========= */
@media (max-width: 768px) {
    .page-shell { padding: 24px; }
    .page-header {
        padding: 24px;
        flex-direction: column;
        gap: 16px;
        align-items: flex-start;
    }
    .page-header h2 { font-size: 28px; }
    .stats-container {
        flex-direction: column;
    }
    .table-container {
        padding: 20px;
        overflow-x: auto;
    }
    .table {
        min-width: 600px;
    }
}
</style>

<div class="page-shell">
    <div class="page-container">
        <!-- Page Header -->
        <div class="page-header">
            <h2><i class="fas fa-users"></i> User Management</h2>
            <a href="{{ path('admin_users_new') }}" class="btn btn-primary mb-3">
                <i class="fas fa-plus"></i> Create User
            </a>
        </div>

        <!-- Stats Cards -->
        <div class="stats-container">
            <div class="stat-card">
                <h3>Total Users</h3>
                <p>{{ totalUsers }}</p>
            </div>

            <div class="stat-card">
                <h3>Total Admins</h3>
                <p>{{ totalAdmins }}</p>
            </div>

            <div class="stat-card">
                <h3>Total Staff</h3>
                <p>{{ totalStaff }}</p>
            </div>
        </div>

        <!-- Users Table -->
        <div class="table-container">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Username</th>
                        <th>Roles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.id }}</td>
                        <td>{{ user.username }}</td>
                        <td>{{ user.roles|join(', ') }}</td>
                        <td>
                            <a href="{{ path('admin_users_edit', {id: user.id}) }}" class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}" style="display:inline-block"
                                  onsubmit="return confirm('Are you sure?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}