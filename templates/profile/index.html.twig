{% extends 'base.html.twig' %}

{% block title %}Profile | JMB Prints{% endblock %}

{% block navbar %}
    {% include 'profile/_profile_navbar.html.twig' %}
{% endblock %}

{% set can_edit_profile = is_granted('ROLE_ADMIN') or not is_granted('ROLE_STAFF') %}

{% block body %}
{% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_STAFF') %}
<style>.profile-page-wrap { padding-top: 96px; }</style>
{% endif %}
<style>
.profile-flash {
    margin: 0 0 1rem;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 500;
}
.profile-flash--success {
    background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
    color: #065f46;
    border: 1px solid #10b981;
}
.profile-page-wrap {
    font-family: "Poppins", "Inter", sans-serif;
    background: linear-gradient(135deg, #e3f2fd 0%, #f5f6fa 100%);
    padding: 30px 20px;
    min-height: calc(100vh - 80px);
    box-sizing: border-box;
}
.profile-page-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 8px 30px rgba(0, 123, 255, 0.12);
    border: 1px solid rgba(0, 123, 255, 0.1);
    max-width: 640px;
    margin: 0 auto;
    overflow: hidden;
}
.profile-page-card__header {
    padding: 28px 32px 20px;
    border-bottom: 1px solid #e8f1fc;
    background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%);
}
.profile-page-card__header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #007bff;
    margin: 0 0 6px;
}
.profile-page-card__header p {
    margin: 0;
    font-size: 0.9rem;
    color: #6c757d;
}
.profile-page-card__body {
    padding: 28px 32px 32px;
}
.profile-dl {
    margin: 0;
    display: grid;
    gap: 1.25rem;
}
.profile-dl dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6c757d;
    font-weight: 600;
    margin-bottom: 0.35rem;
}
.profile-dl dd {
    margin: 0;
    font-size: 1.05rem;
    color: #333;
    font-weight: 500;
    word-break: break-word;
}
.profile-admin-actions {
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e8f1fc;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
}
.profile-admin-actions a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 10px 18px;
    border-radius: 12px;
    background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
    color: #fff !important;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.profile-admin-actions a:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0, 123, 255, 0.35);
}
.profile-admin-actions a.profile-link--secondary {
    background: #fff;
    color: #007bff !important;
    border: 2px solid #007bff;
    box-shadow: none;
}
.profile-admin-actions a.profile-link--secondary:hover {
    background: #f0f7ff;
}
</style>

<div class="profile-page-wrap">
    <div class="profile-page-card">
        <div class="profile-page-card__header">
            <h1>Your profile</h1>
            {% if is_granted('ROLE_STAFF') and not is_granted('ROLE_ADMIN') %}
                <p>Account details are shown below. To change your information, contact an administrator.</p>
            {% else %}
                <p>Account details are shown below. Use Edit profile to update your name, email, or password.</p>
            {% endif %}
        </div>
        <div class="profile-page-card__body">
            {% for message in app.flashes('success') %}
                <p class="profile-flash profile-flash--success" role="status">{{ message }}</p>
            {% endfor %}
            <dl class="profile-dl">
                <div>
                    <dt>Name (username)</dt>
                    <dd>{{ user.userIdentifier }}</dd>
                </div>
                <div>
                    <dt>Email</dt>
                    <dd>{{ user.email ?? '—' }}</dd>
                </div>
                <div>
                    <dt>Role</dt>
                    <dd>{{ primary_role_label }}</dd>
                </div>
                <div>
                    <dt>Email verified</dt>
                    <dd>{% if user.verified %}Yes{% else %}No{% endif %}</dd>
                </div>
            </dl>

            {% if can_edit_profile %}
                <div class="profile-admin-actions">
                    <a href="{{ path('app_profile_edit') }}">
                        <i class="fas fa-pen-to-square" aria-hidden="true"></i>
                        Edit profile
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('user_management_index') }}" class="profile-link--secondary">
                            <i class="fas fa-users-cog" aria-hidden="true"></i>
                            User management
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
