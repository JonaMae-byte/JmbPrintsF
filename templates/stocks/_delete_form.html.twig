

{% if is_granted('ROLE_ADMIN') %}
<form method="post" action="{{ path('app_stocks_delete', {'id': stock.id}) }}" 
      onsubmit="return confirm('Are you sure you want to delete this stock? This action cannot be undone.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ stock.id) }}">
    <button type="submit" class="btn btn-delete">
        <i class="fas fa-trash-alt"></i> Delete Stock
    </button>
</form>
{% endif %}
