{% extends 'base.html.twig' %}

{% block title %}Register | JMB Prints{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
{% endblock %}

{% block body %}

<style>

/* ========================================
   AUTHENTICATION PAGES STYLES
   (Registration, Login, Reset Password)
======================================== */

.auth-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background-color: #f7f9fc;
    position: relative;
}

.auth-layout {
    width: 100%;
    max-width: 1080px;
    display: grid;
    grid-template-columns: minmax(320px, 440px) minmax(360px, 1fr);
    gap: 24px;
    align-items: stretch;
    position: relative;
    z-index: 1;
}

.auth-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
        linear-gradient(135deg, rgba(0, 91, 150, 0.03) 0%, rgba(0, 123, 255, 0.03) 100%);
    pointer-events: none;
}

.auth-card {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 48px 40px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.5);
    width: 100%;
    max-width: 440px;
    position: relative;
    animation: fadeInUp 0.6s ease-out;
}

.auth-visual {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    min-height: 690px;
    background: #d6ebff;
}

.auth-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.auth-header {
    text-align: center;
    margin-bottom: 32px;
}

.auth-logo {
    display: inline-block;
    margin-bottom: 24px;
}

.auth-logo img {
    width: 80px;
    height: 80px;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.95);
    padding: 12px;
    border-radius: 16px;
    box-shadow: 0 4px 16px rgba(0, 91, 150, 0.15);
}

.auth-header h1 {
    font-size: 28px;
    font-weight: 700;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 8px 0;
}

.auth-header p {
    color: #718096;
    font-size: 15px;
    margin: 0;
}

.alert {
    padding: 14px 18px;
    border-radius: 12px;
    margin-bottom: 24px;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.alert-error {
    background: #fee;
    color: #c53030;
    border: 1px solid #feb2b2;
}

.alert-success {
    background: #f0fdf4;
    color: #166534;
    border: 1px solid #86efac;
}

.auth-form {
    margin-bottom: 24px;
}

.form-group {
    margin-bottom: 20px;
}

.form-label {
    display: block;
    margin-bottom: 8px;
    color: #2d3748;
    font-weight: 600;
    font-size: 14px;
}

.form-input {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 15px;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: all 0.3s ease;
    background: white;
    box-sizing: border-box;
}

.form-input:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
}

.form-input::placeholder {
    color: #a0aec0;
}

.form-group-checkbox {
    margin-bottom: 24px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
}

.form-checkbox {
    width: 18px;
    height: 18px;
    cursor: pointer;
    flex-shrink: 0;
    margin-top: 2px;
}

.checkbox-label {
    color: #4a5568;
    font-size: 14px;
    line-height: 1.5;
    cursor: pointer;
    user-select: none;
}

.checkbox-label a {
    color: #007bff;
    text-decoration: none;
    font-weight: 600;
}

.checkbox-label a:hover {
    text-decoration: underline;
}

.btn-submit {
    width: 100%;
    padding: 14px 24px;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(0, 91, 150, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 91, 150, 0.4);
}

.btn-submit:active {
    transform: translateY(0);
}

.auth-footer {
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid #e2e8f0;
}

.auth-footer p {
    color: #718096;
    font-size: 14px;
    margin: 0;
}

.auth-footer a {
    color: #007bff;
    text-decoration: none;
    font-weight: 600;
}

.auth-footer a:hover {
    text-decoration: underline;
}

.form-error {
    color: #e53e3e;
    font-size: 13px;
    margin-top: 6px;
    display: block;
}

ul.form-error {
    list-style: none;
    padding: 0;
    margin: 6px 0 0 0;
}

ul.form-error li {
    margin-bottom: 4px;
}

@media (max-width: 980px) {
    .auth-layout {
        grid-template-columns: 1fr;
        max-width: 440px;
    }

    .auth-visual {
        display: none;
    }
}

@media (max-width: 480px) {
    .auth-card {
        padding: 32px 24px;
    }

    .auth-header h1 {
        font-size: 24px;
    }

    .auth-logo img {
        width: 64px;
        height: 64px;
    }
}

</style>

<div class="auth-container">
    <div class="auth-layout">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <img src="{{ asset('SADlogo.png') }}" alt="JMB Prints Logo">
                </div>
                <h1>Create Account</h1>
                <p>Join JMB Prints today</p>
            </div>

            {% if form_errors(registrationForm) %}
                <div class="alert alert-error">
                    {{ form_errors(registrationForm) }}
                </div>
            {% endif %}

            {{ form_start(registrationForm, {'attr': {'class': 'auth-form'}}) }}

                <div class="form-group">
                    {{ form_label(registrationForm.username, 'Username', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.username, {'attr': {'class': 'form-input', 'placeholder': 'Enter your username'}}) }}
                    {{ form_errors(registrationForm.username) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-input', 'placeholder': 'Enter your email address'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword, 'Password', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-input', 'placeholder': 'Enter your password'}}) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                <div class="form-group-checkbox">
                    {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-checkbox'}}) }}
                    {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'checkbox-label'}}) }}
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="btn-submit">
                    <i class="fas fa-user-plus"></i>
                    Register
                </button>

            {{ form_end(registrationForm) }}

            <div class="auth-footer">
                <p>Already have an account? <a href="{{ path('app_login') }}">Login here</a></p>
            </div>
        </div>

        <div class="auth-visual" aria-hidden="true">
            <img src="{{ asset('auth-images/auth-side.png') }}" alt="">
        </div>
    </div>
</div>
{% endblock %}
