{% extends 'base.html.twig' %}

{% block title %}Checkout | JMB Prints{% endblock %}

{% block body %}
<style>
/* ========= NAVBAR - CONSISTENT DESIGN ========= */
.checkout-navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: linear-gradient(180deg, #005b96 0%, #007bff 100%);
    padding: 16px 40px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 2000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 24px;
    font-weight: 700;
    color: white;
    text-decoration: none;
    transition: all 0.3s ease;
}

.nav-logo:hover {
    transform: scale(1.05);
    color: white;
}

.nav-logo i {
    color: white;
}

.nav-actions {
    display: flex;
    align-items: center;
    gap: 28px;
}

.nav-cart-link {
    position: relative;
    font-size: 24px;
    color: white;
    text-decoration: none;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
}

.nav-cart-link:hover {
    color: rgba(255, 255, 255, 0.8);
    transform: scale(1.1);
}

.nav-cart-badge {
    position: absolute;
    top: -8px;
    right: -12px;
    background: linear-gradient(135deg, #dc3545, #c82333);
    color: white;
    border-radius: 50%;
    min-width: 22px;
    height: 22px;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(220, 53, 69, 0.4);
}

.profile-menu {
    position: relative;
}

.profile-trigger {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.profile-trigger:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.3);
}

.profile-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 16px;
}

.profile-name {
    font-weight: 600;
    color: white;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
}

.profile-name i {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.7);
}

.profile-dropdown {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    background: white;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    border-radius: 12px;
    overflow: hidden;
    min-width: 200px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    animation: dropdownFade 0.3s ease-out;
}

@keyframes dropdownFade {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.profile-menu:hover .profile-dropdown {
    display: block;
}

.profile-dropdown a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    text-decoration: none;
    color: #4a5568;
    font-size: 15px;
    font-weight: 500;
    transition: all 0.2s ease;
}

.profile-dropdown a:hover {
    background: #f8f9fa;
    color: #007bff;
    padding-left: 24px;
}

.profile-dropdown a i {
    font-size: 16px;
    width: 20px;
    text-align: center;
}

.divider {
    height: 1px;
    background: #e2e8f0;
    margin: 6px 0;
}

.logout {
    color: #dc3545 !important;
}

.logout:hover {
    background: #fee !important;
    color: #dc3545 !important;
}

/* ========= CHECKOUT CONTAINER ========= */
.checkout-container {
    padding: 32px;
    padding-top: 110px;
    max-width: 1200px;
    margin: 0 auto;
}

/* ========= PAGE HEADER ========= */
.checkout-header {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 32px;
    border-radius: 20px;
    margin-bottom: 32px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.5);
    animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.checkout-header h1 {
    font-size: 36px;
    font-weight: 700;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 8px 0;
}

.checkout-header p {
    color: #718096;
    font-size: 16px;
    margin: 0;
}

.alert-stack {
    margin-bottom: 20px;
    display: grid;
    gap: 10px;
}

.alert {
    padding: 12px 14px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
}

.alert-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
}

.alert-success {
    background: #ecfdf3;
    border: 1px solid #86efac;
    color: #166534;
}

/* ========= CHECKOUT CONTENT ========= */
.checkout-content {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 32px;
}

/* ========= CUSTOMER INFO SECTION ========= */
.customer-info-section {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.5);
}

.section-title {
    font-size: 24px;
    font-weight: 700;
    color: #2d3748;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
}

.section-title i {
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.form-group {
    margin-bottom: 24px;
}

.form-group label {
    display: block;
    font-weight: 600;
    color: #2d3748;
    margin-bottom: 8px;
    font-size: 15px;
}

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 14px 18px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 15px;
    outline: none;
    transition: all 0.3s ease;
    background: white;
    font-family: 'Inter', sans-serif;
}

.form-group input:focus,
.form-group textarea:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 4px rgba(0, 123, 255, 0.1);
}

.form-group textarea {
    resize: vertical;
    min-height: 100px;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

/* ========= ORDER SUMMARY SECTION ========= */
.order-summary-section {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.5);
    height: fit-content;
    position: sticky;
    top: 110px;
}

/* ========= ORDER ITEMS ========= */
.order-items {
    margin-bottom: 24px;
}

.order-item {
    display: flex;
    justify-content: space-between;
    align-items: start;
    padding: 16px 0;
    border-bottom: 1px solid #e2e8f0;
}

.order-item:last-child {
    border-bottom: none;
}

.item-details {
    flex: 1;
}

.item-name {
    font-weight: 600;
    color: #2d3748;
    font-size: 15px;
    margin-bottom: 4px;
}

.item-quantity {
    color: #718096;
    font-size: 14px;
}

.item-price {
    font-weight: 700;
    color: #005b96;
    font-size: 16px;
}

/* ========= ORDER TOTALS ========= */
.order-totals {
    padding-top: 24px;
    border-top: 2px solid #e2e8f0;
}

.total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.total-label {
    font-size: 15px;
    color: #4a5568;
}

.total-value {
    font-weight: 600;
    color: #2d3748;
    font-size: 15px;
}

.grand-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 12px;
    margin-top: 16px;
}

.grand-total-label {
    font-size: 18px;
    font-weight: 700;
    color: #2d3748;
}

.grand-total-value {
    font-size: 28px;
    font-weight: 800;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

/* ========= ACTION BUTTONS ========= */
.checkout-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 24px;
}

.btn-place-order {
    width: 100%;
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
    padding: 16px 32px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 16px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.btn-place-order:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(40, 167, 69, 0.4);
}

.btn-place-order:active {
    transform: translateY(0);
}

.btn-back {
    width: 100%;
    background: white;
    color: #4a5568;
    padding: 14px 28px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 15px;
    border: 2px solid #e2e8f0;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.btn-back:hover {
    border-color: #007bff;
    color: #007bff;
    background: #f8f9fa;
}

/* ========= SECURE BADGE ========= */
.secure-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    background: #f0fdf4;
    border: 1px solid #86efac;
    border-radius: 8px;
    margin-top: 16px;
    color: #166534;
    font-size: 13px;
    font-weight: 600;
}

.secure-badge i {
    color: #22c55e;
}

/* ========= RESPONSIVE ========= */
@media (max-width: 992px) {
    .checkout-content {
        grid-template-columns: 1fr;
    }

    .order-summary-section {
        position: static;
    }

    .form-row {
        grid-template-columns: 1fr;
    }

    .profile-name span {
        display: none;
    }
}

@media (max-width: 768px) {
    .checkout-navbar {
        padding: 12px 20px;
    }

    .nav-logo {
        font-size: 18px;
    }

    .checkout-container {
        padding: 20px;
        padding-top: 90px;
    }

    .checkout-header {
        padding: 24px 20px;
    }

    .checkout-header h1 {
        font-size: 28px;
    }

    .customer-info-section,
    .order-summary-section {
        padding: 24px 20px;
    }

    .grand-total-value {
        font-size: 24px;
    }
}
</style>

<!-- Navbar -->
<nav class="checkout-navbar">
    <a href="{{ path('app_ordering') }}" class="nav-logo">
        <i class="fas fa-store"></i>
        <span>JMB Prints</span>
    </a>

    <div class="nav-actions">
        <!-- Cart Icon -->
        <a href="{{ path('cart_index') }}" class="nav-cart-link">
            <i class="fas fa-shopping-cart"></i>
            <span id="cartCount" class="nav-cart-badge">0</span>
        </a>

        <!-- Profile Dropdown -->
        <div class="profile-menu">
            <div class="profile-trigger">
                <div class="profile-avatar">
                    <i class="fas fa-user"></i>
                </div>
                <div class="profile-name">
                    <span>{{ app.user.username|default('User') }}</span>
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>

            <div class="profile-dropdown">
                <a href="{{ path('app_ordering') }}">
                    <i class="fas fa-user-circle"></i>
                    My Profile
                </a>
                <a href="{{ path('app_ordering') }}">
                    <i class="fas fa-shopping-bag"></i>
                    My Orders
                </a>
                <a href="#">
                    <i class="fas fa-cog"></i>
                    Account Settings
                </a>
                <div class="divider"></div>
                <a href="{{ path('app_logout') }}" class="logout">
                    <i class="fas fa-sign-out-alt"></i>
                    Logout
                </a>
            </div>
        </div>
    </div>
</nav>

<!-- Checkout Content -->
<div class="checkout-container">
    <div class="checkout-header">
        <h1>🛍️ Checkout</h1>
        <p>Complete your order and get your custom prints delivered</p>
    </div>

    {% set errorFlashes = app.flashes('error') %}
    {% set successFlashes = app.flashes('success') %}
    {% if errorFlashes is not empty or successFlashes is not empty %}
        <div class="alert-stack">
            {% for message in errorFlashes %}
                <div class="alert alert-error">{{ message }}</div>
            {% endfor %}
            {% for message in successFlashes %}
                <div class="alert alert-success">{{ message }}</div>
            {% endfor %}
        </div>
    {% endif %}

    <form action="{{ path('app_ordering_checkout') }}" method="POST">
        <div class="checkout-content">
            <!-- Left Column: Customer Information -->
            <div class="customer-info-section">
                <h2 class="section-title">
                    <i class="fas fa-user-circle"></i>
                    Customer Information
                </h2>

                <div class="form-group">
                    <label for="customer_name">
                        Full Name <span style="color: #dc3545;">*</span>
                    </label>
                    <input type="text" 
                           id="customer_name" 
                           name="customer_name" 
                           placeholder="Enter your full name"
                           required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="email">
                            Email Address <span style="color: #dc3545;">*</span>
                        </label>
                        <input type="email" 
                               id="email" 
                               name="email" 
                               placeholder="your@email.com"
                               required>
                    </div>

                    <div class="form-group">
                        <label for="phone">
                            Phone Number <span style="color: #dc3545;">*</span>
                        </label>
                        <input type="tel" 
                               id="phone" 
                               name="phone" 
                               placeholder="+63 912 345 6789"
                               required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="address">
                        Delivery Address <span style="color: #dc3545;">*</span>
                    </label>
                    <textarea id="address" 
                              name="address" 
                              placeholder="Enter your complete delivery address"
                              required></textarea>
                </div>

                <div class="form-group">
                    <label for="notes">
                        Order Notes (Optional)
                    </label>
                    <textarea id="notes" 
                              name="notes" 
                              placeholder="Any special instructions for your order?"></textarea>
                </div>
            </div>

            <!-- Right Column: Order Summary -->
            <div class="order-summary-section">
                <h2 class="section-title">
                    <i class="fas fa-receipt"></i>
                    Order Summary
                </h2>

                <div class="order-items">
                    {% set grandTotal = 0 %}
                    {% for id, item in cart %}
                        {% set lineTotal = item.price * item.qty %}
                        {% set grandTotal = grandTotal + lineTotal %}
                        
                        <div class="order-item">
                            <div class="item-details">
                                <div class="item-name">{{ item.name }}</div>
                                <div class="item-quantity">Quantity: {{ item.qty }}</div>
                            </div>
                            <div class="item-price">₱{{ lineTotal|number_format(2) }}</div>
                        </div>
                    {% endfor %}
                </div>

                <div class="order-totals">
                    <div class="total-row">
                        <span class="total-label">Subtotal</span>
                        <span class="total-value">₱{{ grandTotal|number_format(2) }}</span>
                    </div>
                    <div class="total-row">
                        <span class="total-label">Shipping</span>
                        <span class="total-value" style="color: #28a745;">FREE</span>
                    </div>
                    <div class="total-row">
                        <span class="total-label">Tax</span>
                        <span class="total-value">₱0.00</span>
                    </div>

                    <div class="grand-total">
                        <span class="grand-total-label">Total</span>
                        <span class="grand-total-value">₱{{ grandTotal|number_format(2) }}</span>
                    </div>
                </div>

                <div class="checkout-actions">
                    <button type="submit" class="btn-place-order">
                        <i class="fas fa-check-circle"></i>
                        Place Order
                    </button>
                    <a href="{{ path('cart_index') }}" class="btn-back">
                        <i class="fas fa-arrow-left"></i>
                        Back to Cart
                    </a>
                </div>

                <div class="secure-badge">
                    <i class="fas fa-lock"></i>
                    Secure checkout - Your information is safe
                </div>
            </div>
        </div>
    </form>
</div>

<script>
// Update cart badge
function updateCartBadge() {
    fetch("/cart/count")
        .then(r => r.json())
        .then(data => {
            document.getElementById("cartCount").textContent = data.count;
        })
        .catch(() => {});
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', updateCartBadge);

// Form validation feedback
document.querySelector('form').addEventListener('submit', function(e) {
    const requiredFields = this.querySelectorAll('[required]');
    let isValid = true;
    
    requiredFields.forEach(field => {
        if (!field.value.trim()) {
            isValid = false;
            field.style.borderColor = '#dc3545';
        } else {
            field.style.borderColor = '#e2e8f0';
        }
    });
    
    if (!isValid) {
        e.preventDefault();
        alert('Please fill in all required fields');
    }
});
</script>

{% endblock %}