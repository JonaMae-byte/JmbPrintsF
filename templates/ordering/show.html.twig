{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-4">

    <h2>Order Details</h2>
    <p><strong>Order ID:</strong> {{ order.id }}</p>
    <p><strong>Status:</strong> {{ order.status|lower }}</p>
    <p><strong>Date:</strong> {{ order.createdAt|date('Y-m-d H:i') }}</p>

    <h4 class="mt-4">Items</h4>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Category</th>
                <th>Qty</th>
                <th>Price</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            {% for item in order.orderItems %}
                <tr>
                    <td>{{ item.product.name }}</td>
                    <td>{{ item.product and item.product.category ? item.product.category.name : 'Uncategorized' }}</td>
                    <td>{{ item.quantity }}</td>
                    <td>₱{{ item.price }}</td>
                    <td>₱{{ item.subtotal }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}
