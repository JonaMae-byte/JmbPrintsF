{% extends 'base.html.twig' %}

{% block title %}Product List | JMB Prints{% endblock %}

{% block body %}
<style>
/* ========= MAIN CONTENT ========= */
main {
    padding: 32px;
    margin-left: 0 !important;
    transition: none !important;
}

/* ========= PAGE HEADER ========= */
.page-header {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 24px 32px;
    border-radius: 16px;
    margin-bottom: 24px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.5);
}

.page-header h1 {
    font-size: 32px;
    text-align: center;
    font-weight: 700;
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0;
}

/* ========= CONTENT CARD ========= */
.content-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.5);
}

/* ========= ACTION BAR ========= */
.action-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    gap: 20px;
    flex-wrap: wrap;
}

/* ========= SEARCH BAR ========= */
.search-bar {
    display: flex;
    align-items: center;
    gap: 12px;
}

.search-bar input {
    padding: 12px 18px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    font-size: 15px;
    width: 280px;
    outline: none;
    transition: all 0.3s ease;
    font-family: 'Inter', sans-serif;
}

.search-bar input:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
}

.search-bar button {
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
    border: none;
    color: white;
    padding: 12px 24px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(0, 91, 150, 0.3);
    display: flex;
    align-items: center;
    gap: 8px;
}

.search-bar button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 91, 150, 0.4);
}

/* ========= CREATE BUTTON ========= */
.create-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(135deg, #28a745, #20c997);
    color: white;
    padding: 12px 32px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
}

.create-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(40, 167, 69, 0.4);
}

/* ========= TABLE CONTAINER ========= */
.table-container {
    overflow-x: auto;
    border-radius: 12px;
}

/* ========= TABLE ========= */
table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 12px;
    overflow: hidden;
}

thead {
    background: linear-gradient(135deg, #005b96 0%, #007bff 100%);
}

th {
    color: white;
    padding: 16px 20px;
    text-transform: uppercase;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-align: left;
}

th:last-child {
    text-align: center;
}

tbody tr {
    transition: all 0.2s ease;
    border-bottom: 1px solid #f0f0f0;
}

tbody tr:hover {
    background-color: #f8f9fa;
}

tbody tr:last-child {
    border-bottom: none;
}

td {
    padding: 18px 20px;
    font-size: 15px;
    color: #4a5568;
    text-align: left;
}

td:last-child {
    text-align: center;
}

/* ========= PRODUCT IMAGE ========= */
.product-image {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 10px;
    border: 2px solid #e2e8f0;
    transition: all 0.3s ease;
}

.product-image:hover {
    transform: scale(1.1);
    border-color: #007bff;
    box-shadow: 0 4px 12px rgba(0, 123, 255, 0.2);
}

/* ========= PRICE BADGE ========= */
.price-badge {
    display: inline-block;
    background: linear-gradient(135deg, #28a745, #20c997);
    color: white;
    padding: 6px 14px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
}

.stock-badge {
    display: inline-block;
    background: linear-gradient(135deg, #1f7cff, #0058d6);
    color: white;
    padding: 6px 14px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
}

/* ========= ACTION BUTTONS ========= */
.actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
}

.btn {
    padding: 8px 16px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: none;
    cursor: pointer;
}

.btn-show { 
    background: linear-gradient(135deg, #17a2b8, #138496);
    color: white;
    box-shadow: 0 2px 8px rgba(23, 162, 184, 0.3);
}

.btn-show:hover { 
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(23, 162, 184, 0.4);
}

.btn-edit { 
    background: linear-gradient(135deg, #005b96, #007bff);
    color: white;
    box-shadow: 0 2px 8px rgba(0, 91, 150, 0.3);
}

.btn-edit:hover { 
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 91, 150, 0.4);
}

.btn-delete { 
    background: linear-gradient(135deg, #dc3545, #c82333);
    color: white;
    box-shadow: 0 2px 8px rgba(220, 53, 69, 0.3);
}

.btn-delete:hover { 
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(220, 53, 69, 0.4);
}

/* ========= EMPTY STATE ========= */
.empty-state {
    text-align: center;
    padding: 60px 20px;
    color: #718096;
}

.empty-state i {
    font-size: 64px;
    color: #cbd5e0;
    margin-bottom: 16px;
}

.empty-state p {
    font-size: 18px;
    margin: 0;
}

/* ========= RESPONSIVE ========= */
@media (max-width: 768px) {
    main {
        padding: 20px;
    }

    .page-header {
        padding: 20px;
    }

    .page-header h1 {
        font-size: 24px;
    }

    .content-card {
        padding: 20px;
    }

    .action-bar {
        flex-direction: column;
        align-items: stretch;
    }

    .search-bar {
        flex-direction: column;
    }

    .search-bar input {
        width: 100%;
    }

    .search-bar button,
    .create-btn {
        width: 100%;
        justify-content: center;
    }

    .table-container {
        overflow-x: auto;
    }

    table {
        min-width: 800px;
    }
}
</style>

<main>
    <div class="page-header">
        <h1>🛍️ Product Management</h1>
    </div>

    <div class="content-card">
        <div class="action-bar">
            <form class="search-bar" method="get" action="{{ path('app_product_index') }}">
                <input type="text" name="q" placeholder="Search products..." value="{{ app.request.get('q') }}">
                <button type="submit">
                    <i class="fas fa-search"></i>
                    Search
                </button>
            </form>

            <a href="{{ path('app_product_new') }}" class="create-btn">
                <i class="fas fa-plus"></i>
                Create New Product
            </a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product Name</th>
                        <th>Description</th>
                        <th>Price</th>
                        <th>Image</th>
                        <th>Category</th>
                        <th>Stocks</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for product in products %}
                        {% if app.request.get('q') is empty or product.name matches('/' ~ app.request.get('q') ~ '/i') %}
                            <tr>
                                <td><strong>#{{ product.id }}</strong></td>
                                <td><strong>{{ product.name }}</strong></td>
                                <td>{{ product.text }}</td>
                                <td>
                                    <span class="price-badge">₱{{ product.price|number_format(2, '.', ',') }}</span>
                                </td>
                                <td>
                                    {% if product.image %}
                                        <img src="{{ product.image }}" alt="{{ product.name }}" class="product-image">
                                    {% else %}
                                        <span style="color: #cbd5e0;">No image</span>
                                    {% endif %}
                                </td>
                                <td>{{ product.category ? product.category.name : 'No Category' }}</td>
                                <td>
                                    <span class="stock-badge">{{ product.stock ?? 0 }}</span>
                                </td>
                                <td>
                                    <div class="actions">
                                        <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-show">
                                            <i class="fas fa-eye"></i>
                                            View
                                        </a>
                                        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-edit">
                                            <i class="fas fa-edit"></i>
                                            Edit
                                        </a>
                                        {% if is_granted('ROLE_ADMIN') %}
                                        <form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                            <button class="btn btn-danger">Delete</button>
                                        </form>
                                        {% endif %}

                                    </div>
                                </td>
                            </tr>
                        {% endif %}
                    {% else %}
                        <tr>
                            <td colspan="8">
                                <div class="empty-state">
                                    <i class="fas fa-inbox"></i>
                                    <p>No products found.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</main>
{% endblock %}