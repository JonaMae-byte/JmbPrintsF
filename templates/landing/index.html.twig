{% extends 'base.html.twig' %}

{% block title %}Welcome to JMB Prints | Personalized Printing & Design{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --landing-nav-offset: 68px;
    --black:       #05070a;
    --black-soft:  #0a0d12;
    --black-card:  #0f1318;
    --black-hover: #141a22;
    --blue:        #1d6ff2;
    --blue-bright: #3d8fff;
    --blue-glow:   rgba(29, 111, 242, 0.22);
    --blue-dim:    rgba(29, 111, 242, 0.09);
    --gold:        #c9a84c;
    --gold-light:  #e8c97a;
    --white:       #ffffff;
    --white-70:    rgba(255,255,255,0.70);
    --white-40:    rgba(255,255,255,0.40);
    --white-15:    rgba(255,255,255,0.15);
    --white-07:    rgba(255,255,255,0.07);
    --border:      rgba(255,255,255,0.08);
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--landing-nav-offset);
  }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--black);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ── NOISE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.028;
    pointer-events: none;
    z-index: 9998;
  }

  /* ═══════════════════════════════
     HERO
  ═══════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    padding: 0 6% 80px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(5, 7, 10, 0.86) 0%, rgba(5, 7, 10, 0.62) 45%, rgba(5, 7, 10, 0.28) 100%),
      url("https://scontent.fceb1-4.fna.fbcdn.net/v/t39.30808-6/665933316_2564300353985677_4615671101001426012_n.jpg?_nc_cat=107&ccb=1-7&_nc_sid=13d280&_nc_eui2=AeE_eommQOhW8KF44iAb5MeGY8npNTaZQa5jyek1NplBriVp7IE3mGN1DKqciB0B4Secdhwwv4xO4jspaSgNRttq&_nc_ohc=JW0DnPRC4DMQ7kNvwE1Y0-c&_nc_oc=AdqICsLG5eqSABIhImfVDg6AW7oVSwPfjztAG3UqAbUaIfzS0hoHN3x25E70ZyyxsMN2s0BDu8HxLds-3zpUTi9Z&_nc_zt=23&_nc_ht=scontent.fceb1-4.fna&_nc_gid=N9pgryBPc5onWFwrtku83g&_nc_ss=7a3a8&oh=00_Af3sbZseZDMexFX305QVPkJDPMHkMJaPxXjNDxUN4I7NDA&oe=69DAEE71");
    background-size: cover;
    background-position: center right;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8, 12, 18, 0.2) 0%, rgba(5, 7, 10, 0.65) 100%);
    pointer-events: none;
    z-index: 0;
  }

  .hero::after {
    content: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 72px 72px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.35;
  }

  .hero-rule {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), transparent);
    z-index: 1;
  }

  .hero-shell {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    padding-top: var(--landing-nav-offset);
  }

  /* ── NAV ── */
  .hero-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 6%;
    box-sizing: border-box;
    background: rgba(5, 7, 10, 0.88);
    backdrop-filter: saturate(1.15) blur(14px);
    -webkit-backdrop-filter: saturate(1.15) blur(14px);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
  }

  .hero-nav-shell {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .hero-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--white);
    text-decoration: none;
    text-transform: uppercase;
    position: relative;
  }

  .hero-brand span { color: var(--blue-bright); }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .hero-links a {
    color: var(--white-70);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .hero-links a:hover { color: var(--white); }

  .nav-cta {
    color: var(--white) !important;
    background: var(--blue);
    padding: 8px 18px;
    border-radius: 3px;
    font-weight: 600 !important;
    letter-spacing: 0.5px !important;
    transition: background 0.25s, box-shadow 0.25s !important;
  }

  .nav-cta:hover {
    background: var(--blue-bright) !important;
    box-shadow: 0 0 24px rgba(29,111,242,0.45);
  }

  /* ── HERO MAIN ── */
  .hero-main {
    display: block;
    max-width: 700px;
    padding-top: 42px;
    margin-left: 0;
  }

  .hero-content {
    text-align: left;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3.5px;
    text-transform: uppercase;
    color: var(--blue-bright);
    margin-bottom: 30px;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 28px; height: 1px;
    background: var(--blue-bright);
  }

  .hero-content h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(60px, 7vw, 102px);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -1px;
    color: var(--white);
    margin-bottom: 28px;
    text-transform: uppercase;
  }

  .hero-content h1 em {
    font-style: italic;
    color: var(--blue-bright);
  }

  .hero-content h1 .gold-word {
    color: var(--gold-light);
  }

  .hero-content p {
    font-size: clamp(22px, 2.2vw, 26px);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.92);
    max-width: 470px;
    margin-bottom: 42px;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 18px;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--blue);
    color: var(--white);
    font-weight: 600;
    font-size: 14px;
    padding: 16px 34px;
    border-radius: 3px;
    text-decoration: none;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.12), transparent);
    opacity: 0;
    transition: opacity 0.25s;
  }

  .btn-primary:hover {
    background: var(--blue-bright);
    box-shadow: 0 8px 32px rgba(29,111,242,0.5);
    transform: translateY(-2px);
  }

  .btn-primary:hover::before { opacity: 1; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--white-70);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--white-15);
    transition: all 0.2s;
  }

  .btn-ghost:hover {
    color: var(--white);
    border-color: var(--white-40);
    gap: 12px;
  }

  /* ── HERO VISUAL ── */
  .hero-visual {
    display: none;
  }

  .hero-img-frame {
    position: relative;
    width: 100%;
    max-width: 600px;
  }

  .hero-img-frame::before,
  .hero-img-frame::after {
    content: '';
    position: absolute;
    width: 24px; height: 24px;
    border-color: var(--blue);
    border-style: solid;
    z-index: 2;
  }

  .hero-img-frame::before {
    top: -10px; left: -10px;
    border-width: 2px 0 0 2px;
  }

  .hero-img-frame::after {
    bottom: -10px; right: -10px;
    border-width: 0 2px 2px 0;
  }

  .hero-corner-tr,
  .hero-corner-bl {
    position: absolute;
    width: 24px; height: 24px;
    border-color: var(--blue);
    border-style: solid;
    z-index: 2;
    pointer-events: none;
  }

  .hero-corner-tr { top: -10px; right: -10px; border-width: 2px 2px 0 0; }
  .hero-corner-bl { bottom: -10px; left: -10px; border-width: 0 0 2px 2px; }

  .hero-img-frame img {
    width: 100%;
    display: block;
    border-radius: 4px;
    object-fit: cover;
    aspect-ratio: 16/10;
    transition: transform 0.5s ease;
    position: relative;
    z-index: 1;
    filter: brightness(0.92) saturate(1.1);
  }

  .hero-img-frame:hover img { transform: scale(1.02); }

  .hero-img-overlay {
    position: absolute;
    inset: 0;
    border-radius: 4px;
    background: linear-gradient(135deg, rgba(29,111,242,0.12), transparent 60%);
    z-index: 2;
    pointer-events: none;
  }

  .hero-badge {
    position: absolute;
    bottom: -22px;
    left: -22px;
    background: var(--black-card);
    border: 1px solid var(--blue);
    border-radius: 4px;
    padding: 16px 22px;
    z-index: 3;
    line-height: 1.3;
    box-shadow: 0 12px 40px rgba(0,0,0,0.6), 0 0 0 1px rgba(29,111,242,0.2);
  }

  .hero-badge span {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--blue-bright);
    line-height: 1;
  }

  .hero-badge small {
    font-size: 11px;
    color: var(--white-70);
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 500;
  }

  .hero-stat-pill {
    position: absolute;
    top: -18px;
    right: -18px;
    background: var(--blue);
    border-radius: 4px;
    padding: 12px 18px;
    z-index: 3;
    text-align: center;
    box-shadow: 0 8px 28px rgba(29,111,242,0.5);
  }

  .hero-stat-pill strong {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }

  .hero-stat-pill small {
    font-size: 10px;
    color: rgba(255,255,255,0.8);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════
     STATS BAR
  ═══════════════════════════════ */
  .stats-bar {
    background: var(--black-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    position: relative;
    overflow: hidden;
  }

  .stats-bar::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), transparent);
  }

  .stat-item {
    padding: 36px 24px;
    border-right: 1px solid var(--border);
    text-align: center;
    position: relative;
    transition: background 0.3s;
  }

  .stat-item:hover { background: var(--blue-dim); }
  .stat-item:last-child { border-right: none; }

  .stat-item strong {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px;
    font-weight: 700;
    color: var(--blue-bright);
    line-height: 1;
    letter-spacing: -1px;
  }

  .stat-item small {
    font-size: 11px;
    color: var(--white-40);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 8px;
    display: block;
    font-weight: 500;
  }

  /* ═══════════════════════════════
     FEATURES
  ═══════════════════════════════ */
  .features-section {
    padding: 120px 6%;
    background: var(--black-soft);
    position: relative;
    overflow: hidden;
  }

  .features-section::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 1px; height: 80px;
    background: linear-gradient(to bottom, transparent, var(--blue));
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 64px;
  }

  .section-label {
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--blue-bright);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 24px; height: 1px;
    background: var(--blue-bright);
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(40px, 4.2vw, 62px);
    font-weight: 700;
    line-height: 1.05;
    color: var(--white);
    max-width: 520px;
    letter-spacing: -0.3px;
  }

  .section-title em { font-style: italic; color: var(--blue-bright); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .feature-card {
    background: var(--black-card);
    padding: 56px 46px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 2px;
    background: var(--blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .feature-card:hover { background: var(--black-hover); }
  .feature-card:hover::before { transform: scaleX(1); }

  .feature-num {
    position: absolute;
    top: 16px; right: 24px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 94px;
    font-weight: 700;
    color: rgba(29,111,242,0.1);
    line-height: 1;
    pointer-events: none;
  }

  .feature-icon {
    width: 60px; height: 60px;
    border-radius: 4px;
    background: var(--blue-dim);
    border: 1px solid rgba(29,111,242,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    margin-bottom: 28px;
    transition: background 0.3s, border-color 0.3s;
  }

  .feature-card:hover .feature-icon {
    background: rgba(29,111,242,0.18);
    border-color: var(--blue);
  }

  .feature-card h3 {
    font-size: 26px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 16px;
    letter-spacing: -0.3px;
    line-height: 1.2;
  }

  .feature-card p {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.85;
    font-weight: 400;
  }

  /* ═══════════════════════════════
     ABOUT
  ═══════════════════════════════ */
  .about-section {
    padding: 120px 6%;
    background: var(--black);
    position: relative;
    overflow: hidden;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 1px; height: 64px;
    background: linear-gradient(to bottom, transparent, var(--blue));
    opacity: 0.85;
  }

  .about-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(40px, 6vw, 88px);
    align-items: start;
  }

  .about-col--visual {
    min-width: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .about-col--text {
    min-width: 0;
  }

  .about-col--text .section-label { margin-bottom: 16px; }

  .about-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 3.4vw, 48px);
    font-weight: 700;
    line-height: 1.12;
    color: var(--white);
    letter-spacing: -0.5px;
    margin-bottom: 28px;
  }

  .about-copy p {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.9;
    font-weight: 400;
    margin-bottom: 18px;
  }

  .about-copy p:last-child { margin-bottom: 0; }

  .about-actions {
    margin-top: 28px;
  }

  .about-photo-wrap {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 4 / 3;
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.55),
      0 0 0 1px var(--border);
  }

  .about-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-stats-grid {
    display: grid;
    width: 100%;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(2, auto);
    column-gap: 16px;
    row-gap: 16px;
    margin-top: 20px;
    align-items: stretch;
    justify-items: stretch;
  }

  .about-stat-card {
    min-width: 0;
    background: var(--black-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 22px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    transition: border-color 0.25s, box-shadow 0.25s;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    box-sizing: border-box;
  }

  .about-stat-card:hover {
    border-color: rgba(29, 111, 242, 0.28);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(29, 111, 242, 0.12);
  }

  .about-stat-card strong {
    display: block;
    width: 100%;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 2.8vw, 36px);
    font-weight: 700;
    color: var(--blue-bright);
    line-height: 1;
    letter-spacing: -1px;
    text-align: left;
  }

  .about-stat-card small {
    display: block;
    width: 100%;
    margin-top: 8px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--white-40);
    line-height: 1.35;
    text-align: left;
  }

  /* ═══════════════════════════════
     PRODUCTS
  ═══════════════════════════════ */
  .products-section {
    padding: 120px 6%;
    background: var(--black);
    position: relative;
  }

  .products-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 56px;
    gap: 20px;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .product-card {
    background: var(--black-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    cursor: pointer;
  }

  .product-card:hover {
    transform: translateY(-8px);
    border-color: rgba(29,111,242,0.4);
    box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(29,111,242,0.15);
  }

  .product-card-img {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .product-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
    display: block;
    filter: brightness(0.88) saturate(0.9);
  }

  .product-card:hover .product-card-img img {
    transform: scale(1.08);
    filter: brightness(0.75) saturate(1);
  }

  .product-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5,7,10,0.85) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.3s;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 22px;
  }

  .product-card:hover .product-card-overlay { opacity: 1; }

  .product-card-overlay span {
    background: var(--blue);
    color: var(--white);
    font-weight: 600;
    font-size: 12px;
    padding: 9px 22px;
    border-radius: 3px;
    letter-spacing: 1px;
    text-transform: uppercase;
    box-shadow: 0 0 20px rgba(29,111,242,0.5);
  }

  .product-info { padding: 22px 20px; }

  .product-info h4 {
    font-size: 16px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 6px;
    letter-spacing: -0.2px;
  }

  .product-info p {
    font-size: 13px;
    color: var(--white-40);
    line-height: 1.6;
    font-weight: 300;
  }

  /* ═══════════════════════════════
     CONTACT
  ═══════════════════════════════ */
  .contact-section {
    padding: 120px 6%;
    background: var(--black);
    border-top: 1px solid var(--border);
  }

  .contact-card {
    background: var(--black-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px;
  }

  .contact-copy {
    color: var(--white-70);
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 18px;
    max-width: 760px;
  }

  .contact-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .contact-link {
    color: var(--blue-bright);
    text-decoration: none;
    border-bottom: 1px solid rgba(61, 143, 255, 0.5);
    padding-bottom: 2px;
  }

  .contact-link:hover {
    color: var(--white);
    border-color: var(--white-40);
  }

  /* ═══════════════════════════════
     CTA BAND
  ═══════════════════════════════ */
  .cta-band {
    background: var(--black-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 100px 6%;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 60px;
    position: relative;
    overflow: hidden;
  }

  .cta-band::before {
    content: '';
    position: absolute;
    left: -200px; top: 50%;
    transform: translateY(-50%);
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(29,111,242,0.12) 0%, transparent 65%);
    pointer-events: none;
  }

  .cta-band::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), transparent);
  }

  .cta-band h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 3.5vw, 52px);
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.5px;
  }

  .cta-band h2 em { font-style: italic; color: var(--blue-bright); }

  .cta-band p {
    color: var(--white-40);
    font-size: 16px;
    margin-top: 14px;
    font-weight: 300;
    line-height: 1.7;
  }

  /* ═══════════════════════════════
     FOOTER
  ═══════════════════════════════ */
  .landing-footer {
    background: linear-gradient(180deg, rgba(8, 12, 18, 0.96), rgba(5, 7, 10, 1));
    border-top: 1px solid var(--border);
    padding: 54px 6% 28px;
  }

  .landing-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: 34px;
  }

  .footer-brand {
    display: inline-block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    color: var(--white);
    font-weight: 700;
    letter-spacing: 1px;
    text-decoration: none;
    margin-bottom: 10px;
  }

  .footer-brand span { color: var(--blue-bright); }

  .footer-copy {
    color: var(--white-70);
    font-size: 14px;
    line-height: 1.75;
    max-width: 380px;
  }

  .footer-title {
    color: var(--white);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .footer-links {
    list-style: none;
    display: grid;
    gap: 10px;
    padding: 0;
    margin: 0;
  }

  .footer-links a {
    color: var(--white-70);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s ease;
  }

  .footer-links a:hover { color: var(--blue-bright); }

  .footer-bottom {
    max-width: 1280px;
    margin: 26px auto 0;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    color: var(--white-40);
    font-size: 12px;
    letter-spacing: 0.3px;
  }

  /* ═══════════════════════════════
     ANIMATIONS
  ═══════════════════════════════ */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(32px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .hero-eyebrow  { animation: fadeUp 0.6s ease both; }
  .hero-content h1 { animation: fadeUp 0.65s 0.12s ease both; }
  .hero-content p  { animation: fadeUp 0.65s 0.22s ease both; }
  .hero-actions    { animation: fadeUp 0.65s 0.32s ease both; }
  .hero-visual     { animation: fadeUp 0.8s 0.18s ease both; }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  /* ═══════════════════════════════
     RESPONSIVE
  ═══════════════════════════════ */
  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
    .features-grid { grid-template-columns: 1fr; }
    .about-inner { grid-template-columns: minmax(0, 1fr); gap: 40px; }
    .about-heading { max-width: none; }
    .about-copy p { max-width: none; }
  }

  @media (max-width: 768px) {
    :root { --landing-nav-offset: 120px; }
    .hero { padding: 0 5% 60px; }
    .hero-nav { padding: 14px 5%; }
    .hero-nav-shell { justify-content: center; flex-direction: column; gap: 12px; }
    .hero-links { justify-content: center; flex-wrap: wrap; }
    .hero-main { text-align: center; }
    .hero-content p { margin: 0 auto 36px; }
    .hero-actions { justify-content: center; }
    .hero-eyebrow { justify-content: center; }
    .hero-badge { left: 4px; }
    .stats-bar { grid-template-columns: repeat(2, 1fr); }
    .stat-item { border-bottom: 1px solid var(--border); }
    .products-grid { grid-template-columns: 1fr; }
    .cta-band { grid-template-columns: 1fr; }
    .products-header { flex-direction: column; align-items: flex-start; }
    .about-section { padding: 88px 5%; }
    .about-stats-grid {
      column-gap: 12px;
      row-gap: 12px;
    }
    .about-stat-card { padding: 20px 18px; }
    .landing-footer__inner { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .hero-stat-pill { display: none; }
    .landing-footer__inner { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
    * { animation-duration: 0.01ms !important; }
  }
</style>

