</section>

<script>
  (function () {
    const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
    if (!revealItems.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });

    revealItems.forEach((item) => revealObserver.observe(item));
  })();

  (function () {
    const cards = Array.from(document.querySelectorAll('.team-card'));
    if (!cards.length) return;

    const clearZoom = () => {
      cards.forEach((card) => {
        card.classList.remove('is-zoomed');
        const wrap = card.querySelector('.team-photo-wrap');
        if (wrap) wrap.classList.remove('is-zoomed');
      });
    };

    cards.forEach((card) => {
      const wrap = card.querySelector('.team-photo-wrap');
      if (!wrap) return;

      wrap.addEventListener('click', (event) => {
        event.stopPropagation();
        const isOpen = wrap.classList.contains('is-zoomed');
        clearZoom();
        if (!isOpen) {
          card.classList.add('is-zoomed');
          wrap.classList.add('is-zoomed');
        }
      });
    });

    document.addEventListener('click', clearZoom);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') clearZoom();
    });
  })();
</script>



{% endblock %}
