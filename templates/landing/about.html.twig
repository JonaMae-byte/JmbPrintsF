{% extends 'base.html.twig' %}

{% block title %}About Us | JMB Prints{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --landing-nav-offset: 68px;
    --black: #05070a;
    --black-soft: #0a0d12;
    --blue: #1d6ff2;
    --blue-bright: #3d8fff;
    --white: #ffffff;
    --white-70: rgba(255,255,255,0.70);
    --white-40: rgba(255,255,255,0.40);
    --border: rgba(255,255,255,0.08);
  }

  body {
    font-family: 'Outfit', sans-serif;
    background:
      radial-gradient(circle at 14% 8%, rgba(29, 111, 242, 0.16) 0%, transparent 42%),
      radial-gradient(circle at 86% 84%, rgba(232, 201, 122, 0.10) 0%, transparent 34%),
      linear-gradient(180deg, #06090d 0%, #05070a 100%);
    color: var(--white);
    min-height: 100vh;
    overflow-x: hidden;
  }

  .hero-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 6%;
    background: rgba(5, 7, 10, 0.88);
    backdrop-filter: saturate(1.15) blur(14px);
    -webkit-backdrop-filter: saturate(1.15) blur(14px);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
  }

  .hero-nav-shell {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .hero-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--white);
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero-brand span { color: var(--blue-bright); }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .hero-links a {
    color: var(--white-70);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .hero-links a:hover { color: var(--white); }

  .nav-cta {
    color: var(--white) !important;
    background: var(--blue);
    padding: 8px 18px;
    border-radius: 3px;
    font-weight: 600 !important;
  }

  .about-section {
    padding: calc(var(--landing-nav-offset) + 52px) 6% 88px;
    background: linear-gradient(180deg, rgba(9,12,17,0.95), rgba(10,13,18,0.92));
    position: relative;
    overflow: hidden;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: var(--landing-nav-offset);
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 64px;
    background: linear-gradient(to bottom, transparent, var(--blue));
    opacity: 0.85;
  }

  .about-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(40px, 6vw, 88px);
    align-items: start;
  }

  .section-label {
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--blue-bright);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--blue-bright);
  }

  .about-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(32px, 3.4vw, 48px);
    font-weight: 700;
    line-height: 1.12;
    margin-bottom: 20px;
    max-width: 640px;
  }

  .about-copy p {
    color: rgba(255,255,255,0.82);
    font-size: clamp(1.06rem, 1.15vw, 1.18rem);
    line-height: 1.95;
    margin: 0 0 10px;
    max-width: 640px;
  }

  .about-photo-wrap {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 22px 52px rgba(0, 0, 0, 0.45);
    background: var(--black-soft);
  }

  .about-photo-wrap img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .stats-bar {
    max-width: 100%;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: rgba(10, 14, 22, 0.92);
  }

  .stat-item {
    padding: 24px 12px;
    text-align: center;
    border-right: 1px solid var(--border);
  }

  .stat-item:last-child { border-right: 0; }

  .stat-item strong {
    display: block;
    color: var(--blue-bright);
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 3vw, 42px);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-item small {
    color: var(--white-40);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .team-section {
    position: relative;
    padding: 74px 6% 70px;
    background: linear-gradient(180deg, rgba(8,12,18,0.95), rgba(8,11,16,0.98));
    overflow: hidden;
  }

  .team-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), transparent);
  }

  .team-section__inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .team-section__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(42px, 7vw, 86px);
    font-weight: 700;
    line-height: 0.96;
    margin-bottom: 32px;
    letter-spacing: -0.8px;
    position: relative;
  }

  .team-section__headline::after {
    content: 'TEAM';
    position: absolute;
    left: 2px;
    top: 2px;
    color: rgba(61,143,255,0.15);
    z-index: -1;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }

  .team-card {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .team-photo-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.14);
    background: #0b0f15;
    margin-bottom: 14px;
    position: relative;
    cursor: zoom-in;
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
    transform-origin: center center;
  }

  .team-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(10%) brightness(0.92);
    transition: transform 0.4s ease, filter 0.4s ease;
  }

  .team-card:hover .team-photo {
    transform: scale(1.04);
    filter: grayscale(0%) brightness(0.98);
  }

  .team-card.is-zoomed { z-index: 40; }

  .team-photo-wrap.is-zoomed {
    transform: scale(1.22);
    border-color: rgba(61, 143, 255, 0.48);
    box-shadow: 0 26px 60px rgba(0, 0, 0, 0.55);
    cursor: zoom-out;
  }

  .team-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 2.4vw, 34px);
    margin: 0 0 6px;
  }

  .team-role {
    margin: 0 0 8px;
    font-size: clamp(11px, 0.95vw, 13px);
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9ec2ff;
  }

  .team-desc {
    color: rgba(255,255,255,0.8);
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.6;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 1024px) {
    .about-inner { grid-template-columns: minmax(0, 1fr); gap: 34px; }
    .about-heading, .about-copy p { max-width: none; }
  }

  @media (max-width: 768px) {
    .about-section { padding: calc(var(--landing-nav-offset) + 36px) 5% 70px; }
    .stats-bar { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .stat-item { border-bottom: 1px solid var(--border); }
    .stat-item:nth-child(2n) { border-right: 0; }
    .team-section { padding: 60px 5% 60px; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 520px) {
    .team-grid { grid-template-columns: 1fr; }
    .team-photo-wrap.is-zoomed { transform: scale(1.08); }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

{% include 'landing/_landing_nav.html.twig' %}

