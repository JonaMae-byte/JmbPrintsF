{% extends 'base.html.twig' %}

{% block title %}Team | JMB Prints{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --landing-nav-offset: 68px;
    --black: #05070a;
    --black-soft: #0a0d12;
    --blue: #1d6ff2;
    --blue-bright: #3d8fff;
    --white: #ffffff;
    --white-40: rgba(255,255,255,0.40);
    --border: rgba(255,255,255,0.08);
  }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--black-soft);
    color: var(--white);
    min-height: 100vh;
    overflow-x: hidden;
  }

  .hero-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 6%;
    background: rgba(5, 7, 10, 0.88);
    backdrop-filter: saturate(1.15) blur(14px);
    -webkit-backdrop-filter: saturate(1.15) blur(14px);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
  }

  .hero-nav-shell {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .hero-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--white);
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero-brand span { color: var(--blue-bright); }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .hero-links a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .hero-links a:hover { color: var(--white); }

  .nav-cta {
    color: var(--white) !important;
    background: var(--blue);
    padding: 8px 18px;
    border-radius: 3px;
    font-weight: 600 !important;
  }

  .team-section {
    position: relative;
    padding: calc(var(--landing-nav-offset) + 54px) 6% 0;
    background: var(--black-soft);
    overflow: hidden;
  }

  .team-section::before {
    content: '';
    position: absolute;
    top: var(--landing-nav-offset);
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), transparent);
  }

  .team-section__inner {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding-bottom: 120px;
  }

  .section-label {
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--blue-bright);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--blue-bright);
  }

  .team-section__headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(52px, 9vw, 110px);
    font-weight: 700;
    line-height: 0.95;
    margin-bottom: 44px;
    letter-spacing: -1px;
    position: relative;
  }

  .team-section__headline::after {
    content: 'TEAM';
    position: absolute;
    left: 2px;
    top: 2px;
    color: rgba(61,143,255,0.16);
    z-index: -1;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  .team-ed-card {
    position: relative;
    text-align: center;
  }

  .team-ed-photo-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.12);
    background: #0b0f15;
    cursor: zoom-in;
    margin-bottom: 16px;
    position: relative;
    transition: border-color 0.3s;
  }

  .team-ed-card:hover .team-ed-photo-wrap {
    border-color: rgba(29,111,242,0.4);
  }

  .team-ed-photo-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 35%, rgba(0,0,0,0.45) 100%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .team-ed-card:hover .team-ed-photo-wrap::after { opacity: 1; }

  .team-ed-photo-wrap::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 2px;
    background: var(--blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    z-index: 2;
  }

  .team-ed-card:hover .team-ed-photo-wrap::before { transform: scaleX(1); }

  .team-ed-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease, filter 0.45s ease;
    filter: grayscale(15%) brightness(0.9);
  }

  .team-ed-card:hover .team-ed-photo {
    transform: scale(1.06);
    filter: grayscale(0%) brightness(0.95);
  }

  .team-ed-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    margin: 0 0 8px;
  }

  .team-ed-role {
    margin: 0 0 10px;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #9ec2ff;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .team-ed-role-icon {
    width: 14px;
    height: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .team-ed-role-icon svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .team-ed-desc {
    color: rgba(255,255,255,0.72);
    font-size: 14px;
    line-height: 1.65;
    transition: color 0.3s;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  .team-ed-card:hover .team-ed-desc { color: rgba(255,255,255,0.88); }

  .team-section__torn {
    display: block;
    width: 100%;
    height: clamp(22px, 4vw, 36px);
    background: linear-gradient(to right, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.03) 100%);
    clip-path: polygon(0 34%, 5% 52%, 12% 30%, 20% 52%, 28% 31%, 35% 50%, 43% 33%, 51% 52%, 58% 32%, 66% 50%, 73% 34%, 81% 52%, 88% 31%, 95% 50%, 100% 35%, 100% 100%, 0 100%);
    opacity: 0.35;
  }

  .lightbox-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0);
    opacity: 0;
    pointer-events: none;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.35s ease, opacity 0.35s ease, backdrop-filter 0.35s ease;
    backdrop-filter: blur(0px);
  }

  .lightbox-overlay.active {
    background: rgba(0,0,0,0.9);
    opacity: 1;
    pointer-events: all;
    backdrop-filter: blur(8px);
  }

  .lightbox-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    transform: scale(0.93) translateY(16px);
    opacity: 0;
    transition: transform 0.35s ease, opacity 0.35s ease;
    max-width: 90vw;
  }

  .lightbox-overlay.active .lightbox-inner {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .lightbox-inner img {
    width: min(460px, 85vw);
    height: min(460px, 85vw);
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.2);
    box-shadow: 0 40px 100px rgba(0,0,0,0.8), 0 0 0 1px rgba(29,111,242,0.3);
  }

  .lightbox-caption { text-align: center; color: #fff; }

  .lightbox-caption strong {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    margin-bottom: 6px;
  }

  .lightbox-caption .lb-role {
    display: block;
    font-size: 10px;
    color: var(--blue-bright);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .lightbox-caption .lb-desc {
    display: block;
    font-size: 13px;
    color: var(--white-40);
    line-height: 1.7;
    font-weight: 300;
  }

  .lightbox-close {
    position: absolute;
    top: -16px;
    right: -16px;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 999px;
    background: rgba(14, 20, 30, 0.9);
    color: #fff;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
    box-shadow: 0 0 20px rgba(29,111,242,0.5);
  }

  .lightbox-close:hover {
    background: var(--blue-bright);
    transform: rotate(90deg) scale(1.1);
  }

  @media (max-width: 1024px) {
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .team-section { padding: calc(var(--landing-nav-offset) + 36px) 5% 0; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .team-grid { grid-template-columns: 1fr; max-width: 300px; margin: 0 auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .team-ed-card:hover .team-ed-photo { transform: none; }
    .lightbox-inner { transition: none; }
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

