{% extends 'base.html.twig' %}

{% block title %}Why Us | JMB Prints{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --landing-nav-offset: 68px;
    --black:       #05070a;
    --black-soft:  #0a0d12;
    --black-card:  #0f1318;
    --black-hover: #141a22;
    --blue:        #1d6ff2;
    --blue-bright: #3d8fff;
    --gold-light:  #e8c97a;
    --white:       #ffffff;
    --white-78:    rgba(255,255,255,0.78);
    --white-55:    rgba(255,255,255,0.55);
    --border:      rgba(255,255,255,0.08);
  }

  body {
    font-family: 'Outfit', sans-serif;
    background:
      radial-gradient(circle at 16% 8%, rgba(29, 111, 242, 0.12) 0%, transparent 40%),
      radial-gradient(circle at 88% 84%, rgba(232, 201, 122, 0.06) 0%, transparent 32%),
      linear-gradient(180deg, #06090d 0%, #05070a 100%);
    color: var(--white);
    overflow-x: hidden;
  }

  .hero-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 6%;
    background: rgba(5, 7, 10, 0.88);
    backdrop-filter: saturate(1.15) blur(14px);
    border-bottom: 1px solid var(--border);
  }

  .hero-nav-shell {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .hero-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--white);
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero-brand span { color: var(--blue-bright); }

  .hero-links { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; justify-content: flex-end; }
  .hero-links a {
    color: rgba(255,255,255,0.70);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }
  .hero-links a:hover { color: var(--white); }

  .nav-cta {
    color: var(--white) !important;
    background: var(--blue);
    padding: 8px 18px;
    border-radius: 3px;
    font-weight: 600 !important;
  }

  .why-page {
    padding: calc(var(--landing-nav-offset) + 52px) 6% 92px;
    background: linear-gradient(180deg, rgba(9,12,17,0.95), rgba(10,13,18,0.92));
    min-height: 100vh;
  }

  .why-shell { max-width: 1280px; margin: 0 auto; }

  .section-label {
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--blue-bright);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .section-label::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--blue-bright);
  }

  .why-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(40px, 5vw, 66px);
    line-height: 1.04;
    margin-bottom: 10px;
  }

  .why-heading em { color: var(--blue-bright); font-style: italic; }
  .why-heading .gold { color: var(--gold-light); }

  .why-sub {
    color: var(--white-78);
    max-width: 760px;
    line-height: 1.8;
    margin-bottom: 28px;
  }

  .why-layout {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 18px;
    align-items: stretch;
  }

  .why-media {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--black-card);
    min-height: 420px;
    position: relative;
  }

  .why-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.8) saturate(1.05);
  }

  .why-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5,7,10,0.1), rgba(5,7,10,0.65));
    pointer-events: none;
  }

  .why-points {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: rgba(10, 14, 22, 0.9);
  }

  .point {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: 12px;
    padding: 18px 18px 16px;
    border-bottom: 1px solid var(--border);
  }

  .point:last-child { border-bottom: 0; }

  .point-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    line-height: 1;
    color: rgba(61, 143, 255, 0.3);
    text-align: center;
  }

  .point h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.55rem;
    margin-bottom: 4px;
  }

  .point p {
    color: var(--white-55);
    line-height: 1.65;
    font-size: 0.93rem;
  }

  .cta-wrap {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--blue), var(--blue-bright));
    color: var(--white);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.93rem;
    padding: 11px 16px;
    border-radius: 7px;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(232, 201, 122, 0.35);
    color: var(--white-78);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.92rem;
    padding: 11px 16px;
    border-radius: 7px;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 980px) {
    .why-layout { grid-template-columns: 1fr; }
    .why-media { min-height: 300px; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

{% include 'landing/_landing_nav.html.twig' %}

<main class="why-page">
  <div class="why-shell">
    <div class="section-label" data-reveal>Why Choose Us</div>
    <h1 class="why-heading" data-reveal style="--reveal-delay: 90ms;">Quality You Can <em>See</em> and <span class="gold">Feel</span></h1>
    <p class="why-sub" data-reveal style="--reveal-delay: 160ms;">We focus on craftsmanship, consistency, and communication. Every custom order is handled with attention to detail so your output looks premium and arrives with confidence.</p>

    <section class="why-layout" aria-label="Why choose JMB Prints">
      <article class="why-media" data-reveal>
        <img src="https://scontent.fceb1-2.fna.fbcdn.net/v/t39.30808-6/660213542_2559830997765946_2709079322622936621_n.jpg?stp=dst-jpg_p180x540_tt6&_nc_cat=111&ccb=1-7&_nc_sid=13d280&_nc_eui2=AeG55rql-MTn4o3fD4rtVbi7IRjxuwa5VY4hGPG7BrlVjrOdwIAjOyLvDsGWmYJxC-o6Va-bFHTGGLRSxFnla_Xm&_nc_ohc=PamgHIU66IYQ7kNvwGyYF-K&_nc_oc=Adq-wt_wR5YLGx2b8ZgGgSwQQWrViwSNK9k9dHjLkugJp8UOAalw7I_o3UbcgKTNZDzHqJ-ur4zm1EXr1lwhXZih&_nc_zt=23&_nc_ht=scontent.fceb1-2.fna&_nc_gid=gN4xaEJXvIvqWHSkGkdhnA&_nc_ss=7a3a8&oh=00_Af3xU9oRdeMXWQ4R1H4YTh71pj3Tx4MerO0K3HhXUR5xdA&oe=69DAFFB1" alt="JMB Prints quality work">
      </article>

      <article class="why-points" data-reveal style="--reveal-delay: 70ms;">
        <div class="point" data-reveal style="--reveal-delay: 120ms;">
          <div class="point-num">01</div>
          <div>
            <h3>Custom Printing</h3>
            <p>Personalized apparel, mugs, and accessories produced with clean finishing and durable quality.</p>
          </div>
        </div>
        <div class="point" data-reveal style="--reveal-delay: 180ms;">
          <div class="point-num">02</div>
          <div>
            <h3>Creative Design Support</h3>
            <p>We help refine your concept into a polished layout that matches your goals and audience.</p>
          </div>
        </div>
        <div class="point" data-reveal style="--reveal-delay: 240ms;">
          <div class="point-num">03</div>
          <div>
            <h3>Reliable Turnaround</h3>
            <p>Clear timelines, consistent updates, and quality checks before release for dependable delivery.</p>
          </div>
        </div>
      </article>
    </section>

    <div class="cta-wrap" data-reveal style="--reveal-delay: 180ms;">
      <a class="btn-primary" href="{{ path('app_contact') }}">Talk to Our Team</a>
      <a class="btn-secondary" href="{{ path('app_landing_products') }}">View Product Options</a>
    </div>
  </div>
</main>
<script>
  (function () {
    const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
    if (!revealItems.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });

    revealItems.forEach((item) => revealObserver.observe(item));
  })();
</script>
{% endblock %}
