{% extends 'base.html.twig' %}

{% block title %}Contact Us | JMB Prints{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --landing-nav-offset: 68px;
    --black:       #05070a;
    --black-card:  #0f1318;
    --blue:        #1d6ff2;
    --blue-bright: #3d8fff;
    --gold:        #c9a84c;
    --white:       #ffffff;
    --white-70:    rgba(255,255,255,0.70);
    --white-15:    rgba(255,255,255,0.15);
    --border:      rgba(255,255,255,0.08);
    --ok-bg:       rgba(34, 197, 94, 0.12);
    --ok-border:   rgba(34, 197, 94, 0.35);
    --ok-text:     #86efac;
  }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--black);
    color: var(--white);
    min-height: 100vh;
  }

  .hero-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 6%;
    background: rgba(5, 7, 10, 0.88);
    backdrop-filter: saturate(1.15) blur(14px);
    border-bottom: 1px solid var(--border);
  }

  .hero-nav-shell {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .hero-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--white);
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero-brand span { color: var(--blue-bright); }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .hero-links a {
    color: var(--white-70);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .hero-links a:hover { color: var(--white); }

  .nav-cta {
    color: var(--white) !important;
    background: var(--blue);
    padding: 8px 18px;
    border-radius: 3px;
    font-weight: 600 !important;
  }

  .nav-cta:hover {
    background: var(--blue-bright) !important;
    box-shadow: 0 0 24px rgba(29,111,242,0.45);
  }

  .contact-page {
    max-width: 1280px;
    margin: 0 auto;
    padding: calc(var(--landing-nav-offset) + 48px) 6% 80px;
    position: relative;
  }

  .contact-page::before {
    content: '';
    position: absolute;
    top: calc(var(--landing-nav-offset) + 10px);
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(61, 143, 255, 0.6), transparent);
  }

  .contact-page h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: 12px;
  }

  .contact-page h1 em {
    font-style: italic;
    color: var(--gold);
  }

  .contact-lead {
    color: var(--white-70);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .contact-feedback {
    border: 1px solid var(--ok-border);
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.13), rgba(5, 7, 10, 0.65));
    border-radius: 12px;
    padding: 18px 20px;
    margin-bottom: 18px;
    color: var(--ok-text);
    font-size: 0.95rem;
    line-height: 1.55;
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(10px);
  }

  .contact-feedback strong { color: #bbf7d0; }

  .contact-open-link {
    display: inline-block;
    margin-top: 10px;
    color: var(--blue-bright);
    font-size: 0.9rem;
    text-underline-offset: 3px;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .contact-open-link:hover {
    color: #84b7ff;
    opacity: 0.95;
  }

  .iframe-wrap {
    position: relative;
    background: linear-gradient(145deg, #111827 0%, #0f1318 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    overflow: hidden;
    min-height: 720px;
    box-shadow:
      0 24px 54px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(29, 111, 242, 0.12) inset;
    padding: 14px;
    width: min(100%, 1100px);
  }

  .iframe-center {
    display: grid;
    place-items: center;
    width: 100%;
  }

  .iframe-wrap {
    margin-inline: auto;
  }

  .iframe-wrap::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue), var(--blue-bright));
    z-index: 2;
  }

  .iframe-wrap iframe {
    display: block;
    width: 100%;
    min-height: 1100px;
    border: 0;
    background: var(--white);
    border-radius: 10px;
  }

  .contact-placeholder {
    border: 1px dashed var(--white-15);
    border-radius: 12px;
    padding: 32px 24px;
    color: var(--white-70);
    line-height: 1.6;
  }

  .contact-placeholder code {
    display: block;
    margin-top: 12px;
    padding: 12px;
    background: rgba(0,0,0,0.35);
    border-radius: 6px;
    font-size: 0.85rem;
    word-break: break-all;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 640px) {
    .hero-links { gap: 16px; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

{% include 'landing/_landing_nav.html.twig' %}

<main class="contact-page" id="contact-main">
  <h1 data-reveal>Contact <em>Us</em></h1>
  <p class="contact-lead" data-reveal style="--reveal-delay: 90ms;">
    Send us a message using the form below. We read every submission and will get back to you as soon as we can.
  </p>

  {% if contact_form_embed_url %}
    <div class="contact-feedback" role="status" aria-live="polite" data-reveal style="--reveal-delay: 130ms;">
      <strong>What happens when you submit?</strong>
      Google hosts this form. After you click <strong>Submit</strong>, a confirmation line such as
      “Your response has been recorded” appears <strong>inside the form area below</strong> — that means we received your message.
      {% if contact_form_open_url %}
        <a class="contact-open-link" href="{{ contact_form_open_url|e('html_attr') }}" target="_blank" rel="noopener noreferrer">
          Open the form in a new tab if it is hard to see here
        </a>
      {% endif %}
    </div>

    <div class="iframe-center" data-reveal style="--reveal-delay: 180ms;">
      <div class="iframe-wrap">
        <iframe
          title="JMB Prints contact form (Google Forms)"
          src="{{ contact_form_embed_url|e('html_attr') }}"
          allow="clipboard-write"
        ></iframe>
      </div>
    </div>
  {% else %}
    <div class="contact-placeholder" data-reveal style="--reveal-delay: 140ms;">
      <p>
        The contact form is not configured yet. In Google Forms, choose <strong>Send</strong> → <strong>&lt;&gt; Embed HTML</strong>,
        copy the <code>src</code> URL of the iframe, and set it in your environment as:
      </p>
      <code>CONTACT_GOOGLE_FORM_EMBED_URL=https://docs.google.com/forms/d/e/…/viewform?embedded=true</code>
    </div>
  {% endif %}
</main>
<script>
  (function () {
    const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
    if (!revealItems.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });

    revealItems.forEach((item) => revealObserver.observe(item));
  })();
</script>
{% endblock %}
