{% extends 'base.html.twig' %}

{% block body %}
<h2>{{ product.name }}</h2>

<p><strong>Price:</strong> ₱{{ product.price }}</p>
<p>{{ product.description }}</p>

<a href="{{ path('cart_add', { id: product.id }) }}" class="btn btn-success">
    Add to Cart
</a>

<br><br>
<a href="{{ path('shop_index') }}" class="btn btn-secondary">← Back</a>
{% endblock %}
